<!DOCTYPE html>
<html lang="th">
<head><%- include('../partials/head') %>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{background:#0f1117;color:#e8eaf0;font-family:'Inter','Noto Sans Thai',sans-serif;min-height:100vh}
.game-wrap{max-width:520px;margin:0 auto;padding:16px}
.game-header{display:flex;align-items:center;gap:12px;margin-bottom:16px}
.back-btn{background:rgba(255,255,255,.07);border:none;color:#aab;padding:8px 14px;border-radius:8px;cursor:pointer;font-size:14px;text-decoration:none;display:inline-flex;align-items:center;gap:6px}
.back-btn:hover{background:rgba(255,255,255,.12)}
.game-title{font-size:28px;font-weight:800;color:#4ade80}
.score-bar{display:flex;gap:10px;margin-bottom:14px}
.score-box{background:#1e2230;border-radius:10px;padding:10px 18px;text-align:center;flex:1}
.score-label{font-size:11px;color:#667;text-transform:uppercase;letter-spacing:.05em}
.score-val{font-size:22px;font-weight:700;color:#4ade80}
canvas{display:block;border-radius:12px;width:100%;background:#111420}
.controls{display:grid;grid-template-columns:repeat(3,56px);gap:8px;justify-content:center;margin-top:14px}
.d-btn{background:#1e2230;border:none;color:#aab;padding:12px;border-radius:8px;font-size:20px;cursor:pointer;touch-action:manipulation}
.d-btn:active{background:#2a3040}
.new-game-btn{background:#22c55e;color:#000;border:none;padding:12px 28px;border-radius:10px;font-size:16px;font-weight:700;cursor:pointer;display:block;width:100%;margin-top:12px}
.new-game-btn:hover{background:#4ade80}
.overlay{position:relative}
.go-overlay{position:absolute;inset:0;background:rgba(0,0,0,.75);border-radius:12px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;z-index:10}
.go-overlay h2{font-size:28px;font-weight:800;color:#4ade80}
</style>
</head>
<body>
<%- include('../partials/topbar') %>
<div class="game-wrap">
  <div class="game-header">
    <a href="/arcade" class="back-btn">← Arcade</a>
    <span class="game-title">🐍 Snake</span>
  </div>
  <div class="score-bar">
    <div class="score-box"><div class="score-label">คะแนน</div><div class="score-val" id="score">0</div></div>
    <div class="score-box"><div class="score-label">สูงสุด</div><div class="score-val" id="best">0</div></div>
  </div>
  <div class="overlay" id="canvasWrap">
    <canvas id="c" width="400" height="400"></canvas>
    <div class="go-overlay" id="overlay">
      <h2>🐍 Snake</h2>
      <div style="color:#aab;font-size:14px">ใช้ลูกศร / WASD หรือปุ่มด้านล่าง</div>
      <button class="new-game-btn" style="width:auto;padding:10px 32px" onclick="startGame()">เริ่มเกม</button>
    </div>
  </div>
  <div class="controls">
    <div></div>
    <button class="d-btn" onclick="setDir(0,-1)">▲</button>
    <div></div>
    <button class="d-btn" onclick="setDir(-1,0)">◀</button>
    <button class="d-btn" onclick="setDir(0,1)">▼</button>
    <button class="d-btn" onclick="setDir(1,0)">▶</button>
  </div>
  <button class="new-game-btn" onclick="startGame()">เริ่มใหม่</button>
</div>
<script>
const canvas=document.getElementById('c');
const ctx=canvas.getContext('2d');
const COLS=20, ROWS=20, CELL=20;
let snake, dir, nextDir, food, score, best=parseInt(localStorage.getItem('snake_best')||'0'), timer, running=false;

document.getElementById('best').textContent=best;

function startGame(){
  snake=[{x:10,y:10},{x:9,y:10},{x:8,y:10}];
  dir={x:1,y:0}; nextDir={x:1,y:0};
  placeFood(); score=0; running=true;
  document.getElementById('overlay').style.display='none';
  clearInterval(timer);
  timer=setInterval(tick, 120);
}

function placeFood(){
  const body=new Set(snake.map(s=>`${s.x},${s.y}`));
  let f;
  do{f={x:Math.floor(Math.random()*COLS),y:Math.floor(Math.random()*ROWS)};}
  while(body.has(`${f.x},${f.y}`));
  food=f;
}

function setDir(x,y){
  if(x&&dir.x)return; if(y&&dir.y)return;
  nextDir={x,y};
}

function tick(){
  dir=nextDir;
  const head={x:snake[0].x+dir.x,y:snake[0].y+dir.y};
  if(head.x<0||head.x>=COLS||head.y<0||head.y>=ROWS){return gameOver();}
  if(snake.some(s=>s.x===head.x&&s.y===head.y)){return gameOver();}
  snake.unshift(head);
  if(head.x===food.x&&head.y===food.y){
    score+=10; if(score>best){best=score;localStorage.setItem('snake_best',best);}
    document.getElementById('score').textContent=score;
    document.getElementById('best').textContent=best;
    placeFood();
  } else { snake.pop(); }
  draw();
}

function draw(){
  ctx.fillStyle='#111420'; ctx.fillRect(0,0,canvas.width,canvas.height);
  // food
  ctx.fillStyle='#f87171';
  ctx.beginPath(); ctx.arc(food.x*CELL+CELL/2,food.y*CELL+CELL/2,CELL/2-2,0,Math.PI*2); ctx.fill();
  // snake
  snake.forEach((s,i)=>{
    ctx.fillStyle=i===0?'#4ade80':'#22c55e';
    ctx.beginPath(); ctx.roundRect(s.x*CELL+1,s.y*CELL+1,CELL-2,CELL-2,4); ctx.fill();
  });
}

function gameOver(){
  clearInterval(timer); running=false;
  const ov=document.getElementById('overlay');
  ov.innerHTML=`<h2>Game Over!</h2><div style="color:#aab">คะแนน: ${score}</div><button class="new-game-btn" style="width:auto;padding:10px 32px" onclick="startGame()">เล่นใหม่</button>`;
  ov.style.display='flex';
}

document.addEventListener('keydown',e=>{
  const map={ArrowLeft:{x:-1,y:0},ArrowRight:{x:1,y:0},ArrowUp:{x:0,y:-1},ArrowDown:{x:0,y:1},
             KeyA:{x:-1,y:0},KeyD:{x:1,y:0},KeyW:{x:0,y:-1},KeyS:{x:0,y:1}};
  const d=map[e.code];
  if(d){e.preventDefault();if(d.x&&dir.x)return;if(d.y&&dir.y)return;nextDir=d;}
});

// Touch swipe
let tx=0,ty=0;
canvas.addEventListener('touchstart',e=>{tx=e.touches[0].clientX;ty=e.touches[0].clientY;},{passive:true});
canvas.addEventListener('touchend',e=>{
  if(!running)return;
  const dx=e.changedTouches[0].clientX-tx, dy=e.changedTouches[0].clientY-ty;
  if(Math.abs(dx)<15&&Math.abs(dy)<15)return;
  if(Math.abs(dx)>Math.abs(dy))setDir(dx>0?1:-1,0);
  else setDir(0,dy>0?1:-1);
});

// Initial draw
ctx.fillStyle='#111420'; ctx.fillRect(0,0,canvas.width,canvas.height);
</script>
</body>
</html>
