<!DOCTYPE html>
<html lang="th">
<head><%- include('../partials/head') %></head>
<body>
<%- include('../partials/topbar') %>
<main class="hub-main">

  <section class="hub-hero">
    <div class="hub-hero-tag">Personal Space</div>
    <h1 class="hub-name">salty</h1>
    <p class="hub-bio">เรียนภาษา · code · anime · ดนตรี</p>
    <% if (!user) { %>
    <div class="hub-auth">
      <a href="/register" class="btn-primary">เริ่มใช้งาน</a>
      <a href="/login" class="btn-outline">เข้าสู่ระบบ</a>
    </div>
    <% } %>
  </section>

  <section class="hub-grid">
    <a href="/languages" class="hub-card hub-card--lang">
      <div class="hub-card-body">
        <h2>เรียนภาษา</h2>
        <p>English · 日本語 · 中文 — บทเรียน Flashcard SRS XP</p>
      </div>
      <span class="hub-card-arrow">→</span>
    </a>

    <a href="/coding" class="hub-card hub-card--code">
      <div class="hub-card-body">
        <h2>Coding</h2>
        <p>โปรเจกต์ · ภาษาที่ใช้ · สิ่งที่กำลังทำ</p>
      </div>
      <span class="hub-card-arrow">→</span>
    </a>

    <a href="/games" class="hub-card hub-card--games">
      <div class="hub-card-body">
        <h2>เกม & Anime</h2>
        <p>เกมที่เล่น · Anime ที่ดู · รายการโปรด</p>
      </div>
      <span class="hub-card-arrow">→</span>
    </a>

    <a href="/music" class="hub-card hub-card--music">
      <div class="hub-card-body">
        <h2>ดนตรี</h2>
        <p>เพลงที่ฟัง · เครื่องดนตรี · playlist</p>
      </div>
      <span class="hub-card-arrow">→</span>
    </a>
  </section>

</main>
</body>
</html>
