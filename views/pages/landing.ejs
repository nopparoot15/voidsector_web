<!DOCTYPE html>
<html lang="th">
<head><%- include('../partials/head') %></head>
<body>
<%- include('../partials/topbar') %>
<main class="hub-main">

  <section class="hub-hero">
    <div class="hub-hero-tag">Personal Space</div>
    <h1 class="hub-name">salty</h1>
    <p class="hub-bio">เรียนภาษา · code · tools</p>
    <% if (!user) { %>
    <div class="hub-auth">
      <a href="/register" class="btn-primary">เริ่มใช้งาน</a>
      <a href="/login" class="btn-outline">เข้าสู่ระบบ</a>
    </div>
    <% } %>
  </section>

  <section class="hub-grid">
    <a href="/learning" class="hub-card hub-card--lang">
      <div class="hub-card-body">
        <h2>Learning</h2>
        <p>ภาษา · คณิตศาสตร์ · ภาษาคอมพิวเตอร์</p>
      </div>
      <span class="hub-card-arrow">→</span>
    </a>

    <a href="/portfolio" class="hub-card hub-card--code">
      <div class="hub-card-body">
        <h2>Portfolio</h2>
        <p>โปรเจกต์ · Skills</p>
      </div>
      <span class="hub-card-arrow">→</span>
    </a>

    <a href="/tools" class="hub-card hub-card--tools">
      <div class="hub-card-body">
        <h2>Tools</h2>
        <p>Terminal · Calculator · Watch Party · Whiteboard</p>
      </div>
      <span class="hub-card-arrow">→</span>
    </a>

    <a href="/arcade" class="hub-card hub-card--arcade">
      <div class="hub-card-body">
        <h2>Arcade</h2>
        <p>XO · Word Bomb · Trivia Quiz</p>
      </div>
      <span class="hub-card-arrow">→</span>
    </a>
  </section>

</main>
</body>
</html>
