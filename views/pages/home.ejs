<!DOCTYPE html>
<html lang="th">
<head><%- include('../partials/head') %>
<link rel="stylesheet" href="/css/social.css">
<script src="/socket.io/socket.io.js"></script>
<script src="/js/vs-socket.js"></script>
</head>

<% if (!user || user.isGuest) { %>
<!-- ════════════════════════════════════════════════════
     LANDING — not logged in (Facebook-style)
════════════════════════════════════════════════════ -->
<body class="landing-body">
<div class="fb-landing">

  <!-- Left -->
  <div class="fb-landing-left">
    <div class="fb-logo">VoidSector</div>
    <p class="fb-tagline">ติดตามข่าวสาร เชื่อมต่อกับเพื่อน<br>และสนุกไปด้วยกันในที่เดียว</p>
  </div>

  <!-- Right: Login card -->
  <div class="fb-landing-right">
    <div class="fb-login-card">
      <% if (typeof loginError !== 'undefined' && loginError) { %>
        <div class="fb-login-error"><%= loginError %></div>
      <% } %>
      <form method="POST" action="/auth/login" class="fb-login-form">
        <input type="hidden" name="back" value="/">
        <input type="text"     name="email" placeholder="อีเมล หรือ ชื่อผู้ใช้" class="fb-input" required autofocus>
        <input type="password" name="password" placeholder="รหัสผ่าน"           class="fb-input" required>
        <button type="submit" class="fb-btn-login">เข้าสู่ระบบ</button>
        <a href="/login" class="fb-forgot">ลืมรหัสผ่าน?</a>
      </form>
      <div class="fb-divider"></div>
      <a href="/register" class="fb-btn-register">สร้างบัญชีใหม่</a>
    </div>
    <p class="fb-landing-footer">
      <a href="/arcade">🕹 Arcade</a> · <a href="/forum">💬 Forum</a> · <a href="/learning">📚 Learning</a>
    </p>
  </div>

</div>
</body>
</html>
<% } else { %>
<!-- ════════════════════════════════════════════════════
     SOCIAL FEED — logged in
════════════════════════════════════════════════════ -->
<body class="social-body">
<%- include('../partials/topbar') %>

<div class="social-layout">

  <!-- ── LEFT SIDEBAR ──────────────────────────────────────── -->
  <aside class="social-sidebar-left">
    <% if (user) { %>
    <%
      const xp = user.xp || 0;
      const level = Math.floor(Math.sqrt(xp / 100)) + 1;
    %>
    <a href="/profile" class="social-user-card">
      <div class="social-avatar-wrap">
        <% if (user.avatar) { %>
          <img src="<%- user.avatar %>" class="social-avatar-img" alt="avatar">
        <% } else { %>
          <div class="social-avatar-placeholder"><%= (user.username||'?').slice(0,1).toUpperCase() %></div>
        <% } %>
      </div>
      <div class="social-user-info">
        <div class="social-user-name"><%= user.username %></div>
        <div class="social-user-level">Lv.<%= level %> · <%= xp.toLocaleString() %> XP</div>
      </div>
    </a>
    <% } %>

    <nav class="social-nav">
      <a href="/forum"       class="social-nav-item">💬 <span>Forum</span></a>
      <a href="/learning"    class="social-nav-item">📚 <span>Learning</span></a>
      <a href="/arcade"      class="social-nav-item">🕹 <span>Arcade</span></a>
      <a href="/tools"       class="social-nav-item">🛠 <span>Tools</span></a>
      <a href="/leaderboard" class="social-nav-item">🏆 <span>Leaderboard</span></a>
    </nav>
  </aside>

  <!-- ── FEED ──────────────────────────────────────────────── -->
  <main class="social-feed"><% if (user && !user.isGuest) { %><div class="create-post-card">
      <div class="create-post-top">
        <div class="social-avatar-wrap sm">
          <% if (user.avatar) { %>
            <img src="<%- user.avatar %>" class="social-avatar-img" alt="">
          <% } else { %>
            <div class="social-avatar-placeholder sm"><%= (user.username||'?').slice(0,1).toUpperCase() %></div>
          <% } %>
        </div>
        <div class="create-post-trigger" id="cp-trigger">คุณกำลังคิดอะไรอยู่?</div>
      </div>

      <div class="create-post-form hidden" id="cp-form">
        <textarea id="cp-text" class="create-post-textarea" placeholder="คุณกำลังคิดอะไรอยู่?" maxlength="4000" rows="3"></textarea>
        <div id="cp-preview-wrap" class="cp-img-preview-wrap hidden">
          <img id="cp-preview" class="cp-img-preview" alt="preview">
          <button type="button" id="cp-remove-img" class="cp-remove-img">✕</button>
        </div>
        <div class="create-post-actions">
          <label class="cp-img-btn" title="แนบรูป">
            🖼
            <input type="file" id="cp-file" accept="image/*" style="display:none">
          </label>
          <button class="cp-submit-btn" id="cp-submit">โพสต์</button>
        </div>
      </div>
    </div><% } %><div id="feed-list"></div>
    <div id="feed-loading" class="feed-loading">กำลังโหลด…</div>
    <div id="feed-end" class="feed-end hidden">— ดูครบแล้ว —</div>
  </main>


</div><!-- end social-layout -->

<script>
const ME_ID = <%- JSON.stringify(user?.id || null) %>;
const ME_NAME = <%- JSON.stringify(user?.username || '') %>;
const IS_GUEST = <%- JSON.stringify(!!(user?.isGuest)) %>;

// ── helpers ──────────────────────────────────────────────────────
function esc(s){ return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
function timeAgo(d){
  const s=Math.floor((Date.now()-new Date(d))/1000);
  if(s<60) return 'เมื่อกี้';
  if(s<3600) return Math.floor(s/60)+' นาทีที่แล้ว';
  if(s<86400) return Math.floor(s/3600)+' ชั่วโมงที่แล้ว';
  return Math.floor(s/86400)+' วันที่แล้ว';
}
function avatarHtml(avatar, username, size=''){
  if(avatar) return `<img src="${avatar}" class="social-avatar-img${size?' '+size:''}" alt="">`;
  return `<div class="social-avatar-placeholder${size?' '+size:''}">${esc((username||'?').slice(0,1).toUpperCase())}</div>`;
}

// ── Feed ─────────────────────────────────────────────────────────
let feedOffset=0, feedLoading=false, feedDone=false;
const feedList = document.getElementById('feed-list');
const feedLoadingEl = document.getElementById('feed-loading');
const feedEndEl = document.getElementById('feed-end');

function buildPost(p){
  const isOwn = p.user_id === ME_ID;
  return `<div class="post-card" id="post-${p.id}">
    <div class="post-header">
      <div class="social-avatar-wrap sm">${avatarHtml(p.avatar, p.username)}</div>
      <div class="post-meta">
        <a class="post-author" href="/user/${encodeURIComponent(p.username)}">${esc(p.username)}</a>
        <span class="post-time">${timeAgo(p.created_at)}</span>
      </div>
      ${isOwn ? `<button class="post-delete-btn" onclick="deletePost(${p.id})">🗑</button>` : ''}
    </div>
    ${p.text ? `<div class="post-text">${esc(p.text).replace(/\n/g,'<br>')}</div>` : ''}
    ${p.image ? `<img class="post-image" src="${p.image}" alt="รูป" loading="lazy">` : ''}
    <div class="post-actions">
      <button class="post-like-btn ${p.liked?'liked':''}" onclick="toggleLike(${p.id},this)">
        <span class="like-icon">${p.liked?'❤️':'🤍'}</span> <span class="like-count">${p.like_count}</span>
      </button>
      <button class="post-comment-btn" onclick="toggleComments(${p.id})">
        💬 <span id="ccount-${p.id}">${p.comment_count}</span>
      </button>
    </div>
    <div class="post-comments hidden" id="comments-${p.id}">
      <div class="comments-list" id="clist-${p.id}"></div>
      ${!IS_GUEST ? `<div class="comment-input-row">
        <input class="comment-input" placeholder="แสดงความคิดเห็น…" maxlength="1000"
          onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();submitComment(${p.id},this)}">
      </div>` : ''}
    </div>
  </div>`;
}

async function loadFeed(){
  if(feedLoading||feedDone) return;
  feedLoading=true;
  feedLoadingEl.classList.remove('hidden');
  try{
    const r = await fetch(`/api/feed?limit=10&offset=${feedOffset}`);
    const {ok,posts} = await r.json();
    if(!ok||!posts.length){ feedDone=true; feedLoadingEl.classList.add('hidden'); feedEndEl.classList.remove('hidden'); return; }
    posts.forEach(p => feedList.insertAdjacentHTML('beforeend', buildPost(p)));
    feedOffset += posts.length;
    if(posts.length<10){ feedDone=true; feedEndEl.classList.remove('hidden'); feedLoadingEl.classList.add('hidden'); }
  }catch(e){ console.error(e); }
  feedLoading=false;
  feedLoadingEl.classList.add('hidden');
}

if(ME_ID) loadFeed();
window.addEventListener('scroll',()=>{ if(window.innerHeight+scrollY >= document.body.offsetHeight-300) loadFeed(); });

async function toggleLike(id,btn){
  const liked = btn.classList.contains('liked');
  const r = await fetch(`/api/feed/${id}/like`,{method: liked?'DELETE':'POST'});
  const {ok,count} = await r.json();
  if(!ok) return;
  btn.classList.toggle('liked',!liked);
  btn.querySelector('.like-icon').textContent = !liked?'❤️':'🤍';
  btn.querySelector('.like-count').textContent = count;
}

async function toggleComments(id){
  const box = document.getElementById(`comments-${id}`);
  if(box.classList.contains('hidden')){
    box.classList.remove('hidden');
    const list = document.getElementById(`clist-${id}`);
    if(!list.dataset.loaded){ await loadComments(id); list.dataset.loaded='1'; }
  } else { box.classList.add('hidden'); }
}

function buildCommentHtml(c, postId, isReply=false){
  const actionsHtml = `<div class="comment-actions">
    <span class="comment-time">${timeAgo(c.created_at)}</span>
    <button class="comment-action-btn${c.liked?' liked':''}" onclick="likeComment(${c.id},this)">
      ❤ <span class="clc">${c.like_count||0}</span>
    </button>
    ${!isReply?`<button class="comment-action-btn" onclick="toggleReplyInput(${postId},${c.id})">ตอบกลับ</button>`:''}
  </div>`;
  const repliesHtml = !isReply ? `<div class="comment-replies" id="replies-${c.id}"></div>
    <div class="reply-input-row hidden" id="reply-input-${c.id}">
      <input class="comment-input reply-input" placeholder="ตอบกลับ ${esc(c.username)}…" maxlength="1000"
        onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();submitComment(${postId},this,${c.id})}">
    </div>` : '';
  return `<div class="comment-item" id="comment-${c.id}">
    <div class="social-avatar-wrap xs">${avatarHtml(c.avatar,c.username)}</div>
    <div class="comment-body">
      <div class="comment-bubble">
        <a class="comment-author" href="/user/${encodeURIComponent(c.username)}">${esc(c.username)}</a>
        <span class="comment-text">${esc(c.text)}</span>
      </div>
      ${actionsHtml}
      ${repliesHtml}
    </div>
  </div>`;
}

async function loadComments(id){
  const r = await fetch(`/api/feed/${id}/comments`);
  const {comments} = await r.json();
  const list = document.getElementById(`clist-${id}`);
  if(!comments||!comments.length){ list.innerHTML='<div class="comments-empty">ยังไม่มีความคิดเห็น</div>'; return; }
  const top = comments.filter(c=>!c.parent_id);
  const byParent = {};
  comments.filter(c=>c.parent_id).forEach(c=>{
    (byParent[c.parent_id]||(byParent[c.parent_id]=[])).push(c);
  });
  list.innerHTML = top.map(c=>buildCommentHtml(c,id)).join('');
  top.forEach(c=>{
    const repliesEl = document.getElementById(`replies-${c.id}`);
    if(repliesEl && byParent[c.id]) repliesEl.innerHTML = byParent[c.id].map(r=>buildCommentHtml(r,id,true)).join('');
  });
}

async function likeComment(commentId, btn){
  const liked = btn.classList.contains('liked');
  const r = await fetch(`/api/comments/${commentId}/like`,{method:liked?'DELETE':'POST'});
  const {ok,count} = await r.json();
  if(!ok) return;
  btn.classList.toggle('liked',!liked);
  btn.querySelector('.clc').textContent = count;
}

function toggleReplyInput(postId, commentId){
  const row = document.getElementById(`reply-input-${commentId}`);
  if(!row) return;
  const hidden = row.classList.toggle('hidden');
  if(!hidden) row.querySelector('input').focus();
}

async function submitComment(id, input, parentId=null){
  const text = input.value.trim();
  if(!text) return;
  input.value='';
  const body = {text};
  if(parentId) body.parent_id = parentId;
  const r = await fetch(`/api/feed/${id}/comments`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
  const {ok,count,comment} = await r.json();
  if(!ok||!comment) return;
  if(parentId){
    const repliesEl = document.getElementById(`replies-${parentId}`);
    if(repliesEl) repliesEl.insertAdjacentHTML('beforeend', buildCommentHtml(comment,id,true));
    document.getElementById(`reply-input-${parentId}`)?.classList.add('hidden');
  } else {
    const list = document.getElementById(`clist-${id}`);
    list.querySelector('.comments-empty')?.remove();
    list.insertAdjacentHTML('beforeend', buildCommentHtml(comment,id));
  }
  const cnt = document.getElementById(`ccount-${id}`);
  if(cnt) cnt.textContent = Number(cnt.textContent)+1;
}

async function deletePost(id){
  if(!confirm('ลบโพสต์นี้?')) return;
  const r = await fetch(`/api/feed/${id}`,{method:'DELETE'});
  const {ok} = await r.json();
  if(ok) document.getElementById(`post-${id}`)?.remove();
}

// ── Create Post ──────────────────────────────────────────────────
const cpTrigger = document.getElementById('cp-trigger');
const cpForm    = document.getElementById('cp-form');
const cpText    = document.getElementById('cp-text');
const cpFile    = document.getElementById('cp-file');
const cpPreviewWrap = document.getElementById('cp-preview-wrap');
const cpPreview = document.getElementById('cp-preview');
const cpSubmit  = document.getElementById('cp-submit');
let cpImageData = null;

if(cpTrigger) cpTrigger.addEventListener('click',()=>{
  cpTrigger.classList.add('hidden'); cpForm.classList.remove('hidden'); cpText.focus();
});

if(cpFile) cpFile.addEventListener('change',()=>{
  const file = cpFile.files[0];
  if(!file) return;
  if(file.size > 5*1024*1024){ alert('รูปใหญ่เกิน 5MB'); cpFile.value=''; return; }
  const reader = new FileReader();
  reader.onload = e => {
    const img = new Image();
    img.onload = () => {
      const MAX=1200; let w=img.width,h=img.height;
      if(w>MAX){ h=Math.round(h*MAX/w); w=MAX; }
      const canvas=document.createElement('canvas'); canvas.width=w; canvas.height=h;
      canvas.getContext('2d').drawImage(img,0,0,w,h);
      cpImageData = canvas.toDataURL('image/jpeg',0.82);
      cpPreview.src = cpImageData; cpPreviewWrap.classList.remove('hidden');
    };
    img.src = e.target.result;
  };
  reader.readAsDataURL(file);
});

document.getElementById('cp-remove-img')?.addEventListener('click',()=>{
  cpImageData=null; cpFile.value=''; cpPreviewWrap.classList.add('hidden');
});

if(cpSubmit) cpSubmit.addEventListener('click', async ()=>{
  const text = cpText.value.trim();
  if(!text && !cpImageData) return;
  cpSubmit.disabled=true; cpSubmit.textContent='กำลังโพสต์…';
  try{
    const r = await fetch('/api/feed',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({text,image:cpImageData||''})});
    const {ok,post} = await r.json();
    if(ok && post){
      feedList.insertAdjacentHTML('afterbegin', buildPost(post));
      cpText.value=''; cpImageData=null; cpPreviewWrap?.classList.add('hidden');
      cpFile && (cpFile.value=''); cpForm.classList.add('hidden'); cpTrigger?.classList.remove('hidden');
    }
  }catch(e){ console.error(e); }
  cpSubmit.disabled=false; cpSubmit.textContent='โพสต์';
});

// ── Real-time feed updates ────────────────────────────────────────
function bumpPost(card){
  if(feedList.firstElementChild !== card) feedList.prepend(card);
  card.classList.remove('post-bumped');
  void card.offsetWidth;
  card.classList.add('post-bumped');
  setTimeout(() => card.classList.remove('post-bumped'), 1000);
}

if(ME_ID){
  const feedSocket = window.VS_SOCKET || io();

  feedSocket.on('feed:like', ({ post_id, count }) => {
    const card = document.getElementById(`post-${post_id}`);
    if(!card) return;
    const lc = card.querySelector('.like-count');
    if(lc) lc.textContent = count;
    bumpPost(card);
  });

  feedSocket.on('feed:comment', ({ post_id, count, comment }) => {
    const card = document.getElementById(`post-${post_id}`);
    if(!card) return;
    const cc = document.getElementById(`ccount-${post_id}`);
    if(cc) cc.textContent = count;
    // append comment to open list (skip own — submitComment already shows it)
    if(comment.user_id !== ME_ID){
      const list = document.getElementById(`clist-${post_id}`);
      if(list && list.dataset.loaded === '1'){
        list.querySelector('.comments-empty')?.remove();
        list.insertAdjacentHTML('beforeend', buildCommentHtml(comment, post_id));
      }
    }
    bumpPost(card);
  });
}

</script>
</body>
</html>
<% } %>
