<!DOCTYPE html>
<html lang="th">
<head><%- include('../partials/head') %></head>
<body>
<%- include('../partials/topbar') %>
<main class="home-main">

  <div class="home-greeting">
    <h1>สวัสดี, <span class="home-username"><%= user.username %></span> 👋</h1>
    <p class="home-sub">เลือกภาษาที่ต้องการเรียนวันนี้</p>
  </div>

  <div class="home-stats">
    <div class="stat-pill">🔥 <strong><%= user.streak || 0 %></strong> วัน Streak</div>
    <div class="stat-pill">⚡ <strong><%= user.xp || 0 %></strong> XP</div>
    <div class="stat-pill">🏅 Level <strong><%= Math.floor(Math.sqrt((user.xp || 0) / 100)) + 1 %></strong></div>
  </div>

  <% const xp = user.xp || 0; const level = Math.floor(Math.sqrt(xp / 100)) + 1; const xpForLevel = Math.pow(level - 1, 2) * 100; const xpForNext = Math.pow(level, 2) * 100; const pct = Math.min(100, Math.round(((xp - xpForLevel) / (xpForNext - xpForLevel)) * 100)); %>
  <div class="xp-bar-wrap">
    <div class="xp-bar-fill" style="width:<%= pct %>%"></div>
  </div>
  <div class="xp-bar-label">Lv.<%= level %> &nbsp;·&nbsp; <%= xp - xpForLevel %> / <%= xpForNext - xpForLevel %> XP → Lv.<%= level + 1 %></div>

  <div class="lang-grid">
    <a href="/learn/en" class="lang-card">
      <div class="lang-flag">🇬🇧</div>
      <div class="lang-name">English</div>
      <div class="lang-desc">ภาษาอังกฤษสำหรับคนไทย</div>
      <div class="lang-cta">เริ่มเรียน →</div>
    </a>
    <a href="/learn/ja" class="lang-card">
      <div class="lang-flag">🇯🇵</div>
      <div class="lang-name">日本語</div>
      <div class="lang-desc">ภาษาญี่ปุ่นสำหรับคนไทย</div>
      <div class="lang-cta">เริ่มเรียน →</div>
    </a>
    <a href="/learn/zh" class="lang-card">
      <div class="lang-flag">🇨🇳</div>
      <div class="lang-name">中文</div>
      <div class="lang-desc">ภาษาจีนสำหรับคนไทย</div>
      <div class="lang-cta">เริ่มเรียน →</div>
    </a>
  </div>

</main>
</body>
</html>
