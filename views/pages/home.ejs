<!DOCTYPE html>
<html lang="th">
<head>
  <title>Cyber Portal | Home</title>
  <%- include('../partials/head') %>
</head>
<body>
  <div class="background"></div>

  <!-- ✅ NEW TOPBAR (แทน navbar เดิม) -->
  <%- include('../partials/topbar') %>

  <div class="container vs-page">
    <div class="card vs-card">

      <!-- HEADER -->
      <div style="text-align:center;">
        <h1 style="color:#0ff; font-family:'Orbitron'; text-shadow:0 0 10px #0ff; margin:0; letter-spacing:1px;">
          CYBER PORTAL
        </h1>
        <p style="color:#aaa; margin:12px auto 18px; max-width: 820px; line-height:1.7;">
          พื้นที่รวมเครื่องมือ โปรเจกต์ และสิ่งที่กำลังทำ — กด <b style="color:#9ff;">Learn Hub</b> เพื่อเลือกหมวดหมู่และไปดูคอร์สทั้งหมด
        </p></div>

      <!-- PORTAL SECTIONS -->
      <div style="display:grid; grid-template-columns: 1.2fr 0.8fr; gap:16px; margin-top: 12px;">
        <!-- LEFT: Tools + Projects -->
        <div>
          <!-- QUICK TOOLS -->
          <div style="margin-bottom: 16px;">
            <div style="display:flex; align-items:center; gap:12px; margin-bottom: 10px;">
              <div style="color:#0ff; font-family:'Orbitron'; font-size: 13px; letter-spacing:0.7px;">QUICK TOOLS</div>
              <div style="height:1px; flex:1; background: rgba(0,255,255,0.14);"></div>
            </div>

            <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap:12px;">
              <a href="/compiler" style="text-decoration:none;">
                <div style="border:1px solid rgba(0,255,255,0.18); border-radius:12px; padding:16px; min-height:132px; display:flex; flex-direction:column; justify-content:space-between; background: rgba(255,255,255,0.03);">
                  <div style="font-size:24px; margin-bottom:6px;">🧰</div>
                  <div style="color:#0ff; font-family:'Orbitron'; font-size: 13px;">Compiler</div>
                  <div style="color:#aaa; font-size: 12px; margin-top:6px; line-height:1.5;">Compiler เดียวเขียนได้หลายภาษา • Dark mode • รองรับ STDIN (I/O)</div>
                </div>
              </a>

              <a href="/whiteboard" style="text-decoration:none;">
                <div style="border:1px solid rgba(0,255,255,0.18); border-radius:12px; padding:16px; min-height:132px; display:flex; flex-direction:column; justify-content:space-between; background: rgba(255,255,255,0.03);">
                  <div style="font-size:24px; margin-bottom:6px;">🧩</div>
                  <div style="color:#0ff; font-family:'Orbitron'; font-size: 13px;">Realtime Whiteboard</div>
                  <div style="color:#aaa; font-size: 12px; margin-top:6px; line-height:1.5;">วาด/พิมพ์ได้ • ห้องรวม + ห้องส่วนตัวชวนเพื่อน • ลบอัตโนมัติเมื่อห้องว่าง</div>
                </div>
              </a>


              <a href="/watch" style="text-decoration:none;">
                <div style="border:1px solid rgba(255,0,255,0.18); border-radius:12px; padding:16px; min-height:132px; display:flex; flex-direction:column; justify-content:space-between; background: rgba(255,255,255,0.03);">
                  <div style="font-size:24px; margin-bottom:6px;">🎬</div>
                  <div style="color:#ffb3ff; font-family:'Orbitron'; font-size: 13px;">YouTube Watch Party</div>
                  <div style="color:#aaa; font-size: 12px; margin-top:6px; line-height:1.5;">ดู YouTube พร้อมกันแบบเรียลไทม์ • ห้อง Public/Private (YouTube เท่านั้น) • แชร์ลิงก์เข้าได้เลย</div>
                </div>
              </a>

              <a href="/calculator" style="text-decoration:none;">
                <div style="border:1px solid rgba(0,255,255,0.18); border-radius:12px; padding:16px; min-height:132px; display:flex; flex-direction:column; justify-content:space-between; background: rgba(255,255,255,0.03);">
                  <div style="font-size:24px; margin-bottom:6px;">🧮</div>
                  <div style="color:#0ff; font-family:'Orbitron'; font-size: 13px;">Quantum Calculator</div>
                  <div style="color:#aaa; font-size: 12px; margin-top:6px; line-height:1.5;">คำนวณได้ทั้งสมการ/ฟังก์ชัน/ตรีโกณ/ลอการิทึม/หน่วย</div>
                </div>
              </a>

              <a href="/terminal" style="text-decoration:none;">
              <div style="border:1px solid rgba(255,0,255,0.18); border-radius:12px; padding:16px; min-height:132px; display:flex; flex-direction:column; justify-content:space-between; background: rgba(255,255,255,0.03);">
                <div style="font-size:24px; margin-bottom:6px;">🖥</div>
                <div style="color:#ffb3ff; font-family:'Orbitron'; font-size: 13px;">Terminal Simulator</div>
                <div style="color:#aaa; font-size: 12px; margin-top:6px; line-height:1.5;">เล่นคำสั่งแบบปลอดภัย (help/ls/cd/cat/hack)</div>
              </div>
            </a>


              <div style="border:1px dashed rgba(255,0,255,0.16); border-radius:12px; padding:16px; min-height:132px; display:flex; flex-direction:column; justify-content:space-between; background: rgba(255,255,255,0.02);">
                <div style="font-size:24px; margin-bottom:6px;">⚙️</div>
                <div style="color:#ffb3ff; font-family:'Orbitron'; font-size: 13px;">Utility Slot</div>
                <div style="color:#777; font-size: 12px; margin-top:6px; line-height:1.5;">เช่น JSON Formatter / Base64 / Hash</div>
              </div>
            </div>
          </div>

          <!-- PROJECTS -->
          <div>
            <div style="display:flex; align-items:center; gap:12px; margin-bottom: 10px;">
              <div style="color:#0ff; font-family:'Orbitron'; font-size: 13px; letter-spacing:0.7px;">PROJECTS</div>
              <div style="height:1px; flex:1; background: rgba(0,255,255,0.14);"></div>
            </div>

            <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap:12px;">
              <!-- Example project cards (replace with your data later) -->
              <div style="border:1px solid rgba(0,255,255,0.14); border-radius:12px; padding:16px; min-height:132px; display:flex; flex-direction:column; justify-content:space-between; background: rgba(255,255,255,0.02);">
                <div style="display:flex; justify-content:space-between; gap:10px;">
                  <div>
                    <div style="color:#0ff; font-family:'Orbitron'; font-size: 13px;">Discord Bot</div>
                    <div style="color:#aaa; font-size: 12px; margin-top:6px; line-height:1.5;">ระบบ Moderation/Verification พร้อม dashboard</div>
                  </div>
                  <div style="color:#9ff;">🛰️</div>
                </div>
                <div style="margin-top:10px; color:#777; font-size: 12px;">(ในอนาคต: ใส่ลิงก์ demo/docs/github)</div>
              </div>

              <div style="border:1px dashed rgba(0,255,255,0.16); border-radius:12px; padding:16px; min-height:132px; display:flex; flex-direction:column; justify-content:space-between; background: rgba(255,255,255,0.02);">
                <div style="color:#9bb; font-family:'Orbitron'; font-size: 13px;">+ Add Project</div>
                <div style="color:#777; font-size: 12px; margin-top:6px; line-height:1.5;">พื้นที่โชว์โปรเจกต์ใหม่ในอนาคต</div>
              </div>
            </div>
          </div>
        </div>

        <!-- RIGHT: Updates / Notes -->
        <div>
          <!-- LEARN HUB (replace UPDATES) -->
          <div style="display:flex; align-items:center; gap:12px; margin-bottom: 10px;">
            <div style="color:#0ff; font-family:'Orbitron'; font-size: 13px; letter-spacing:0.7px;">LEARN HUB</div>
            <div style="height:1px; flex:1; background: rgba(0,255,255,0.14);"></div>
          </div>

          <a href="/learn/categories" style="text-decoration:none; display:block;">
            <div style="border:1px solid rgba(0,255,255,0.18); border-radius:14px; padding:18px; background: linear-gradient(135deg, rgba(0,255,255,0.08), rgba(255,0,255,0.06));
                        box-shadow: 0 10px 40px rgba(0,0,0,0.35);">
              <div style="display:flex; align-items:center; gap:14px;">
                <div style="width:52px; height:52px; border-radius:16px; display:flex; align-items:center; justify-content:center;
                            background: rgba(0,255,255,0.12); border:1px solid rgba(0,255,255,0.22);">
                  <span style="font-size:22px;">🎓</span>
                </div>
                <div style="min-width:0; flex:1;">
                  <div style="color:#0ff; font-family:'Orbitron'; font-size:16px; letter-spacing:1px; text-shadow:0 0 10px rgba(0,255,255,0.35);">LEARN HUB</div>
                  <div style="color:#b8c6d4; font-size:13px; margin-top:6px; line-height:1.6;">เลือกหมวดหมู่การเรียน แล้วไปดูคอร์สทั้งหมดในหน้า Learn</div>
                </div>
                <div style="color: rgba(0,255,255,0.9); font-size:13px; white-space:nowrap;">Open →</div>
              </div>

              <div style="margin-top:14px; display:flex; gap:10px; flex-wrap:wrap;">
                <div style="padding:8px 12px; border-radius:999px; border:1px solid rgba(0,255,255,0.18); background: rgba(0,0,0,0.18); color:#9ff; font-size:12px;">🌐 ภาษา</div>
                <div style="padding:8px 12px; border-radius:999px; border:1px solid rgba(255,0,255,0.16); background: rgba(0,0,0,0.18); color:#f9f; font-size:12px;">💻 Coding</div>
                <div style="padding:8px 12px; border-radius:999px; border:1px solid rgba(255,255,255,0.10); background: rgba(0,0,0,0.18); color:#cbd5e1; font-size:12px;">➕ เพิ่มหมวดได้ในอนาคต</div>
              </div>
            </div>
          </a>

          <!-- LEADERBOARD (under Learn Hub) -->
          <a href="/leaderboard" style="text-decoration:none; display:block; margin-top:12px;">
            <div style="border:1px solid rgba(255,0,255,0.20); border-radius:14px; padding:18px; background: linear-gradient(135deg, rgba(255,0,255,0.08), rgba(0,255,255,0.05));
                        box-shadow: 0 10px 40px rgba(0,0,0,0.35);">
              <div style="display:flex; align-items:center; gap:14px;">
                <div style="width:52px; height:52px; border-radius:16px; display:flex; align-items:center; justify-content:center;
                            background: rgba(255,0,255,0.12); border:1px solid rgba(255,0,255,0.24);">
                  <span style="font-size:22px;">🏆</span>
                </div>
                <div style="min-width:0; flex:1;">
                  <div style="color:#ffb3ff; font-family:'Orbitron'; font-size:16px; letter-spacing:1px; text-shadow:0 0 10px rgba(255,0,255,0.28);">LEADERBOARD</div>
                  <div style="color:#b8c6d4; font-size:13px; margin-top:6px; line-height:1.6;">ดูอันดับคะแนน Quiz รวมทุกคอร์ส (อัปเดตจากผลล่าสุด)</div>
                </div>
                <div style="color: rgba(255,0,255,0.9); font-size:13px; white-space:nowrap;">View →</div>
              </div>
              <div style="margin-top:14px; display:flex; gap:10px; flex-wrap:wrap;">
                <div style="padding:8px 12px; border-radius:999px; border:1px solid rgba(255,0,255,0.18); background: rgba(0,0,0,0.18); color:#ffb3ff; font-size:12px;">ล่าสุดเท่านั้น</div>
                <div style="padding:8px 12px; border-radius:999px; border:1px solid rgba(0,255,255,0.16); background: rgba(0,0,0,0.18); color:#9ff; font-size:12px;">รวมทุกบท</div>
              </div>
            </div>
          </a>

          <!-- ABOUT ME + DISCORD -->
          <div style="margin-top: 14px;">
            <div style="display:flex; align-items:center; gap:12px; margin-bottom: 10px;">
              <div style="color:#0ff; font-family:'Orbitron'; font-size: 13px; letter-spacing:0.7px;">ABOUT ME</div>
              <div style="height:1px; flex:1; background: rgba(0,255,255,0.14);"></div>
            </div>

            <% const DISCORD_INVITE_URL = "https://discord.gg/WxmdGhFVGJ"; %>

            <div style="border:1px solid rgba(255,0,255,0.16);
                        border-radius:12px;
                        padding:16px; min-height:132px; display:flex; flex-direction:column; justify-content:space-between; background: rgba(255,255,255,0.02);">
              <div style="display:flex; justify-content:space-between; align-items:flex-start; gap:12px;">
                <div>
                  <div style="color:#ffb3ff; font-family:'Orbitron'; font-size: 13px;">Community / Discord</div>
                  <div style="color:#777; font-size: 12px; margin-top:6px; line-height:1.6;">
                    เข้ามาคุย แลกเปลี่ยน หรือแจ้งบั๊ก/ข้อเสนอแนะได้ที่ดิสคอร์ด
                  </div>
                </div>
                <div style="color:#ffb3ff; font-size: 18px;">💬</div>
              </div>

              <a href="<%= DISCORD_INVITE_URL %>"
                 target="_blank"
                 rel="noopener noreferrer"
                 style="margin-top:12px; display:inline-block; text-decoration:none;
                        border-radius:999px; padding:10px 14px; font-size:12px; font-weight:bold;
                        border:1px solid rgba(255,0,255,0.32); background: rgba(255,0,255,0.08); color:#ffb3ff;">
                🎮 Join Discord
              </a>
            </div>
          </div>

        </div>
      </div>

    </div>
  </div>

  <!-- ✅ Topbar script -->
  <script defer src="/js/topbar.js"></script>

  <!-- ✅ Chat dock (มุมขวาล่าง แบบ Facebook) -->
  <script defer src="/js/chat-dock.js"></script>
</body>
</html>
