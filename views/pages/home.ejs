<!DOCTYPE html>
<html lang="th">
<head><%- include('../partials/head') %></head>
<body>
<%- include('../partials/topbar') %>
<main class="hub-main">

  <section class="hub-hero">
    <%
      const xp = user.xp || 0;
      const streak = user.streak || 0;
      const level = Math.floor(Math.sqrt(xp / 100)) + 1;
      const xpForLevel = Math.pow(level - 1, 2) * 100;
      const xpForNext  = Math.pow(level, 2) * 100;
      const xpProgress = xp - xpForLevel;
      const xpNeeded   = xpForNext - xpForLevel;
      const xpPct      = Math.min(100, Math.round((xpProgress / xpNeeded) * 100));
    %>
    <p class="hub-welcome">ยินดีต้อนรับกลับ</p>
    <h1 class="hub-name"><%= user.username %></h1>
    <div class="hub-user-stats">
      <span class="stat-pill">
        <span class="stat-pill-label">🔥 Streak</span>
        <strong><%= streak %> วัน</strong>
      </span>
      <span class="stat-pill">
        <span class="stat-pill-label">⚡ XP</span>
        <strong><%= xp.toLocaleString() %></strong>
      </span>
      <span class="stat-pill">
        <span class="stat-pill-label">⭐ Level</span>
        <strong><%= level %></strong>
      </span>
    </div>
    <div class="xp-progress-wrap">
      <div class="xp-progress-bar">
        <div class="xp-progress-fill" style="width:<%= xpPct %>%"></div>
      </div>
      <div class="xp-progress-label">
        <span>Lv.<%= level %></span>
        <span><%= xpProgress.toLocaleString() %> / <%= xpNeeded.toLocaleString() %> XP → Lv.<%= level + 1 %></span>
      </div>
    </div>
  </section>

  <section class="hub-grid">
    <a href="/learning" class="hub-card hub-card--lang">
      <div class="hub-card-body">
        <h2>Learning</h2>
        <p>ภาษา · คณิตศาสตร์ · ภาษาคอมพิวเตอร์</p>
      </div>
      <span class="hub-card-arrow">→</span>
    </a>

    <a href="/portfolio" class="hub-card hub-card--code">
      <div class="hub-card-body">
        <h2>Portfolio</h2>
        <p>โปรเจกต์ · Skills</p>
      </div>
      <span class="hub-card-arrow">→</span>
    </a>

    <a href="/tools" class="hub-card hub-card--tools">
      <div class="hub-card-body">
        <h2>Tools</h2>
        <p>Terminal · Calculator · Watch Party · Whiteboard</p>
      </div>
      <span class="hub-card-arrow">→</span>
    </a>

    <a href="/arcade" class="hub-card hub-card--arcade">
      <div class="hub-card-body">
        <h2>Arcade</h2>
        <p>XO · Word Bomb · Trivia Quiz</p>
      </div>
      <span class="hub-card-arrow">→</span>
    </a>

    <a href="/forum" class="hub-card hub-card--forum">
      <div class="hub-card-body">
        <h2>Forum</h2>
        <p>กระทู้ · ถามตอบ · พูดคุย</p>
      </div>
      <span class="hub-card-arrow">→</span>
    </a>
  </section>

</main>
</body>
</html>
