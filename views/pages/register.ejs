<!DOCTYPE html>
<html lang="th">
<head><%- include('../partials/head') %></head>
<body class="auth-body">
<%- include('../partials/topbar') %>
<main class="auth-main">
  <div class="auth-card">
    <div class="auth-logo">🌐 VoidSector</div>
    <h1 class="auth-title">สมัครสมาชิก</h1>
    <% if (error) { %>
      <div class="alert-error"><%= error %></div>
    <% } %>
    <form method="POST" action="/auth/register" class="auth-form">
      <div class="form-group">
        <label for="username">ชื่อผู้ใช้</label>
        <input type="text" id="username" name="username" placeholder="username" required minlength="3" autocomplete="username">
      </div>
      <div class="form-group">
        <label for="email">อีเมล</label>
        <input type="email" id="email" name="email" placeholder="your@email.com" required autocomplete="email">
      </div>
      <div class="form-group">
        <label for="password">รหัสผ่าน</label>
        <input type="password" id="password" name="password" placeholder="อย่างน้อย 6 ตัวอักษร" required minlength="6" autocomplete="new-password">
      </div>
      <button type="submit" class="btn-primary btn-full">สมัครสมาชิกฟรี</button>
    </form>
    <p class="auth-switch">มีบัญชีอยู่แล้ว? <a href="/login">เข้าสู่ระบบ</a></p>
  </div>
</main>
</body>
</html>
