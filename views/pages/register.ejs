<!DOCTYPE html>
<html lang="th">
<head>
  <title>Cyber Portal | Register</title>
  <%- include('../partials/head') %>
</head>
<body>
  <div class="background"></div>
  <%- include('../partials/topbar') %>

  <div class="container vs-page" style="display:flex; justify-content:center;">
    <div class="modal-content"
         style="display:block; width:100%; max-width: 420px;">

      <h2 style="color:#f0f; font-family:'Orbitron'; margin-top:0; text-align:center;">
        REGISTER
      </h2>

      <!-- ✅ แสดง error จาก backend -->
      <% if (typeof error !== 'undefined' && error) { %>
        <div style="margin: 0 0 12px;
                    padding: 10px 12px;
                    border-radius: 10px;
                    border: 1px solid rgba(255,0,255,0.35);
                    background: rgba(255,0,255,0.08);
                    color: #ffb3ff;
                    font-size: 12px;
                    line-height: 1.5;">
          <%= error %>
        </div>
      <% } %>

      <!-- ✅ FORM ยิงเข้า /register -->
      <form method="post" action="/register">
        <input
          type="text"
          name="username"
          placeholder="NEW USERNAME"
          required
          minlength="3"
          autocomplete="username"
          style="width:100%; box-sizing:border-box;" />

        <input
          type="password"
          name="password"
          placeholder="NEW PASSWORD"
          required
          minlength="6"
          autocomplete="new-password"
          style="width:100%; box-sizing:border-box;" />

        <input
          type="password"
          name="confirm"
          placeholder="CONFIRM PASSWORD"
          required
          minlength="6"
          autocomplete="new-password"
          style="width:100%; box-sizing:border-box;" />

        <button
          type="submit"
          class="btn-cyber"
          style="width:100%;
                 padding:12px;
                 background:#f0f;
                 color:#000;
                 font-weight:bold;
                 border:none;
                 margin-bottom: 12px;">
          CREATE ACCOUNT
        </button>
      </form>

      <div style="display:flex; justify-content:space-between; gap:10px;">
        <a href="/login"
           style="color:#0ff; text-decoration:underline; font-size: 12px;">
          มีบัญชีอยู่แล้ว? เข้าสู่ระบบ
        </a>
        <a href="/"
           style="color:#777; text-decoration:underline; font-size: 12px;">
          กลับหน้าแรก
        </a>
      </div>

    </div>
  </div>
</body>
</html>
