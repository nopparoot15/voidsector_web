<!DOCTYPE html>
<html lang="th">
<head><%- include('../partials/head') %></head>
<body>
<%- include('../partials/topbar') %>
<main class="profile-main">
  <div class="profile-card">
    <div class="profile-avatar"><%= userData.username.slice(0,1).toUpperCase() %></div>
    <h1 class="profile-username"><%= userData.username %></h1>
    <p class="profile-email"><%= userData.email %></p>
    <div class="profile-level">Level <%= level %></div>
  </div>

  <div class="profile-stats">
    <div class="stat-card">
      <div class="stat-icon">⚡</div>
      <div class="stat-value"><%= userData.xp || 0 %></div>
      <div class="stat-label">XP ทั้งหมด</div>
    </div>
    <div class="stat-card">
      <div class="stat-icon">🔥</div>
      <div class="stat-value"><%= userData.streak || 0 %></div>
      <div class="stat-label">Streak วัน</div>
    </div>
    <div class="stat-card">
      <div class="stat-icon">✅</div>
      <div class="stat-value"><%= completedCount %></div>
      <div class="stat-label">บทเรียนที่ผ่านแล้ว</div>
    </div>
  </div>

  <div class="profile-actions">
    <a href="/home" class="btn-primary">กลับหน้าหลัก</a>
    <a href="/logout" class="btn-outline">ออกจากระบบ</a>
  </div>
</main>
</body>
</html>
