<!DOCTYPE html>
<html lang="th">
<head><%- include('../partials/head') %></head>
<body>
<%- include('../partials/topbar') %>
<main class="profile-main">
  <div class="profile-card">
    <div class="profile-avatar-wrap">
      <% if (target.avatar) { %>
        <img src="<%- target.avatar %>" class="profile-avatar-img" alt="avatar">
      <% } else { %>
        <div class="profile-avatar"><%= target.username.slice(0,1).toUpperCase() %></div>
      <% } %>
    </div>
    <h1 class="profile-username"><%= target.username %></h1>
    <div class="profile-level">Level <%= level %></div>

    <div class="profile-actions" style="margin-top:16px" id="friend-action-wrap">
      <% if (isFriend) { %>
        <span class="btn-outline" style="cursor:default">🤝 เป็นเพื่อนกันแล้ว</span>
      <% } else if (requestSent) { %>
        <span class="btn-outline" style="cursor:default">⏳ รอการตอบรับ</span>
        <button class="btn-outline" id="cancel-friend-btn" style="margin-left:8px;border-color:rgba(255,80,80,.4);color:#f87171">✕ ยกเลิก</button>
      <% } else { %>
        <button class="btn-primary" id="add-friend-btn">+ เพิ่มเพื่อน</button>
      <% } %>
    </div>
    <div id="friend-msg" style="font-size:13px;margin-top:8px;min-height:18px;color:rgba(235,245,255,.6)"></div>
  </div>

  <div class="profile-stats">
    <div class="stat-card">
      <div class="stat-icon">⚡</div>
      <div class="stat-value"><%= target.xp || 0 %></div>
      <div class="stat-label">XP ทั้งหมด</div>
    </div>
    <div class="stat-card">
      <div class="stat-icon">🔥</div>
      <div class="stat-value"><%= target.streak || 0 %></div>
      <div class="stat-label">Streak วัน</div>
    </div>
    <div class="stat-card">
      <div class="stat-icon">✅</div>
      <div class="stat-value"><%= completedCount %></div>
      <div class="stat-label">บทเรียนที่ผ่านแล้ว</div>
    </div>
  </div>

  <div class="profile-actions" style="margin-top:24px">
    <a href="/" class="btn-outline">← กลับ</a>
  </div>
</main>
<script>
const TARGET_USERNAME = '<%= target.username %>';
const msg = document.getElementById('friend-msg');

// ── เพิ่มเพื่อน ───────────────────────────────────────────────────
const addBtn = document.getElementById('add-friend-btn');
if (addBtn) addBtn.addEventListener('click', async () => {
  addBtn.disabled = true;
  const r = await fetch('/friends/request', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ username: TARGET_USERNAME })
  });
  const { ok } = await r.json();
  if (ok) {
    document.getElementById('friend-action-wrap').innerHTML =
      `<span class="btn-outline" style="cursor:default">⏳ รอการตอบรับ</span>
       <button class="btn-outline" id="cancel-friend-btn" style="margin-left:8px;border-color:rgba(255,80,80,.4);color:#f87171">✕ ยกเลิก</button>`;
    msg.textContent = 'ส่งคำขอเพิ่มเพื่อนแล้ว';
    bindCancel();
  } else {
    msg.textContent = 'เกิดข้อผิดพลาด ลองใหม่อีกครั้ง';
    addBtn.disabled = false;
  }
});

// ── ยกเลิกคำขอ ────────────────────────────────────────────────────
function bindCancel() {
  const cancelBtn = document.getElementById('cancel-friend-btn');
  if (!cancelBtn) return;
  cancelBtn.addEventListener('click', async () => {
    cancelBtn.disabled = true;
    const r = await fetch('/friends/request', {
      method: 'DELETE',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ username: TARGET_USERNAME })
    });
    const { ok } = await r.json();
    if (ok) {
      document.getElementById('friend-action-wrap').innerHTML =
        `<button class="btn-primary" id="add-friend-btn">+ เพิ่มเพื่อน</button>`;
      msg.textContent = 'ยกเลิกคำขอแล้ว';
      document.getElementById('add-friend-btn').addEventListener('click', async () => {
        location.reload();
      });
    } else {
      msg.textContent = 'เกิดข้อผิดพลาด';
      cancelBtn.disabled = false;
    }
  });
}
bindCancel();
</script>
</body>
</html>
