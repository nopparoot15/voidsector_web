<!DOCTYPE html>
<html lang="th">
<head><%- include('../partials/head') %>
<link rel="stylesheet" href="/css/arcade.css">
<script>
  window.__ROOM_ID__ = '<%- roomId %>';
  window.__USER__    = <%- JSON.stringify(user) %>;
</script>
</head>
<body>
<%- include('../partials/topbar') %>
<div class="gm-page">

  <div class="gm-topbar">
    <a href="/arcade" class="gm-back">← Arcade</a>
    <div class="gm-room-info">
      <span class="gm-room-label">ห้อง</span>
      <span class="gm-room-id"><%- roomId %></span>
      <button class="gm-copy-btn" id="copy-link-btn">🔗 แชร์</button>
    </div>
    <div class="gm-players" id="gm-players"></div>
  </div>

  <!-- ══ LOBBY ══════════════════════════════════════════════════════════════ -->
  <div id="sf-lobby" class="sf-lobby">
    <div class="sf-lobby-card">
      <div class="sf-lobby-icon">🕵️</div>
      <h2 class="sf-lobby-title">Spyfall</h2>
      <div class="sf-lobby-room">ห้อง <strong><%- roomId %></strong></div>

      <div class="sf-lobby-rules">
        <div class="sf-rule-row">🎭 ทุกคนรู้สถานที่และบทบาท <b>ยกเว้นสปาย 1 คน</b></div>
        <div class="sf-rule-row">🎤 ถามตอบกันใน Discord — อย่าเปิดเผยสถานที่ตรงๆ</div>
        <div class="sf-rule-row">🚨 กล่าวหาให้ทุกคนโหวต ถ้าจับสปายได้ผู้เล่นชนะ</div>
        <div class="sf-rule-row">🕵️ สปายชนะถ้าเดาสถานที่ถูก หรือรอดจนหมดเวลา</div>
      </div>

      <div id="sf-lobby-players" class="sf-lobby-players"></div>

      <div class="sf-time-picker">
        <span class="sf-time-label">เวลา</span>
        <div class="sf-time-options" id="sf-time-group">
          <button class="sf-time-btn" data-minutes="5">5 นาที</button>
          <button class="sf-time-btn active" data-minutes="8">8 นาที</button>
          <button class="sf-time-btn" data-minutes="10">10 นาที</button>
        </div>
      </div>

      <button id="sf-start-btn" class="sf-start-btn hidden">เริ่มเกม ▶</button>
      <div id="sf-lobby-hint" class="sf-lobby-hint">รอเจ้าของห้องเริ่มเกม…</div>
    </div>
  </div>

  <!-- ══ GAME ════════════════════════════════════════════════════════════════ -->
  <div id="sf-game" class="sf-game hidden">

    <!-- LEFT: main gameplay -->
    <div class="sf-game-main">

      <!-- Timer + Turn -->
      <div class="sf-game-header">
        <div class="sf-timer-block">
          <div id="sf-timer" class="sf-timer">8:00</div>
          <div class="sf-timer-label">เหลือเวลา</div>
        </div>
        <div id="sf-turn-banner" class="sf-turn-banner hidden"></div>
      </div>

      <!-- Player card -->
      <div id="sf-card-player" class="sf-rolecard sf-rolecard--player hidden">
        <div class="sf-rolecard-icon">📍</div>
        <div class="sf-rolecard-row">
          <div class="sf-rolecard-label">สถานที่</div>
          <div id="sf-my-location" class="sf-rolecard-value">—</div>
        </div>
        <div class="sf-rolecard-sep"></div>
        <div class="sf-rolecard-row">
          <div class="sf-rolecard-label">บทบาทของคุณ</div>
          <div id="sf-my-role" class="sf-rolecard-value sf-rolecard-value--role">—</div>
        </div>
      </div>

      <!-- Spy card -->
      <div id="sf-card-spy" class="sf-rolecard sf-rolecard--spy hidden">
        <div class="sf-rolecard-icon">🕵️</div>
        <div class="sf-rolecard-spy-title">คุณคือสปาย</div>
        <div class="sf-rolecard-spy-sub">หาให้ออกว่าอยู่ที่ไหน — อย่าให้ใครจับได้</div>

        <div class="sf-locs-header">
          <span id="sf-loc-label" class="sf-locs-label">กดเลือกสถานที่เพื่อเดา</span>
        </div>
        <div id="sf-location-list" class="sf-locs-grid"></div>

        <div id="sf-guess-inline" class="sf-guess-inline hidden">
          <div id="sf-guess-inline-timer" class="sf-guess-inline-timer hidden"></div>
          <div class="sf-guess-actions">
            <button id="sf-guess-cancel-btn" class="sf-guess-cancel-btn">ยกเลิก</button>
            <button id="sf-guess-confirm-btn" class="sf-guess-confirm-btn" disabled>เลือกสถานที่ก่อน</button>
          </div>
        </div>
      </div>

      <!-- Player list -->
      <div class="sf-players-section">
        <div class="sf-section-label">ผู้เล่นในห้อง</div>
        <div id="sf-player-list" class="sf-player-list"></div>
      </div>

    </div><!-- end sf-game-main -->

    <!-- RIGHT: guide panel -->
    <aside class="sf-guide">
      <div class="sf-guide-title">📖 วิธีเล่น Spyfall</div>

      <div class="sf-guide-section">
        <div class="sf-guide-section-head">🎯 เป้าหมาย</div>
        <p class="sf-guide-p">ผู้เล่นทุกคนรู้ <b>สถานที่</b> และ <b>บทบาท</b> ยกเว้น <b>สปาย 1 คน</b> ที่ไม่รู้ว่าอยู่ที่ไหน ทีมผู้เล่นต้องจับสปายให้ได้ก่อนหมดเวลา ส่วนสปายต้องแกล้งทำเป็นรู้สถานที่และเดาให้ถูกก่อนโดนจับ</p>
      </div>

      <div class="sf-guide-section">
        <div class="sf-guide-section-head">🔄 ลำดับการเล่น</div>
        <div class="sf-guide-steps">
          <div class="sf-guide-step"><span class="sf-step-num">1</span><span>เจ้าของห้องกด <b>เริ่มเกม</b> — ทุกคนได้รับบทบาทลับในโทรศัพท์ตัวเอง</span></div>
          <div class="sf-guide-step"><span class="sf-step-num">2</span><span>ผู้เล่นที่มีเทิร์น <b>ถาม</b> คนอื่น 1 คำถาม ผ่าน Discord แล้วกดปุ่ม <b>ถาม</b> ส่งเทิร์นให้คนนั้นตอบ</span></div>
          <div class="sf-guide-step"><span class="sf-step-num">3</span><span>คนที่โดนถาม <b>ตอบ</b> แล้วกด <b>ถามต่อ</b> เพื่อเลือกถามคนถัดไป</span></div>
          <div class="sf-guide-step"><span class="sf-step-num">4</span><span>เมื่อสงสัยใคร กด <b>กล่าวหา</b> — ทุกคนโหวตพร้อมกัน</span></div>
          <div class="sf-guide-step"><span class="sf-step-num">5</span><span>ถ้าจับสปายได้ สปายต้องเดาสถานที่ — เดาถูกสปายยังชนะ เดาผิดทีมผู้เล่นชนะ</span></div>
        </div>
      </div>

      <div class="sf-guide-section">
        <div class="sf-guide-section-head">🎤 เทคนิคการถาม</div>
        <div class="sf-guide-tips-list">
          <div class="sf-guide-tip">ถามเกี่ยวกับ <b>ประสบการณ์</b> ในสถานที่ เช่น "คุณรู้สึกยังไงที่นี่?" แทนที่จะถามตรงๆ</div>
          <div class="sf-guide-tip">ใช้คำถาม <b>ปลายเปิด</b> เช่น "อธิบายสิ่งที่เห็นรอบตัวให้ฟังหน่อย" — สปายจะตอบได้ยากกว่า</div>
          <div class="sf-guide-tip">สังเกต <b>ความลังเล</b> หรือคำตอบที่คลุมเครือผิดปกติ — นั่นคือสัญญาณของสปาย</div>
          <div class="sf-guide-tip">อย่าถามสิ่งที่ <b>เฉพาะเจาะจงเกินไป</b> เช่น "มีสระว่ายน้ำไหม?" เพราะจะทำให้สปายรู้สถานที่ได้ง่ายขึ้น</div>
          <div class="sf-guide-tip">ถามให้ <b>ทุกคนตอบได้สม่ำเสมอ</b> อย่าเจาะแค่คนที่สงสัย ไม่งั้นจะโดนสปายจับทาง</div>
        </div>
      </div>

      <div class="sf-guide-section">
        <div class="sf-guide-section-head">🕵️ เทคนิคสปาย</div>
        <div class="sf-guide-tips-list">
          <div class="sf-guide-tip">ตอบให้ <b>กว้างและคลุมเครือ</b> เช่น "ก็ปกติ" "ขึ้นอยู่กับคน" — อย่าตอบตรงเกินไปจนคนอื่นรู้ว่าไม่รู้จริง</div>
          <div class="sf-guide-tip">ฟัง <b>คำตอบของทุกคน</b> อย่างตั้งใจ — นั่นคือเบาะแสเดียวที่จะช่วยให้เดาสถานที่ได้</div>
          <div class="sf-guide-tip">ถ้าถูกถามเรื่องที่ไม่รู้ <b>ย้อนถามกลับ</b> หรือพูดว่า "แล้วคุณล่ะ คิดว่ายังไง?"</div>
          <div class="sf-guide-tip">อย่าพยายาม <b>ดูฉลาดเกินไป</b> — สปายที่ถามคำถามแหลมคมมักโดนจับได้ก่อน</div>
          <div class="sf-guide-tip">เดาสถานที่ได้เลยถ้ามั่นใจ — แต่รอให้ <b>ได้ข้อมูลพอ</b> ก่อน เพราะเดาผิดแพ้ทันที</div>
        </div>
      </div>

      <div class="sf-guide-section">
        <div class="sf-guide-section-head">🏆 เงื่อนไขชนะ</div>
        <div class="sf-guide-tips-list">
          <div class="sf-guide-tip sf-guide-tip--green">ทีมผู้เล่น ชนะ ถ้าโหวตจับสปายได้และสปายเดาสถานที่ผิด</div>
          <div class="sf-guide-tip sf-guide-tip--green">ทีมผู้เล่น ชนะ ถ้าสปายประกาศเดาและตอบผิด</div>
          <div class="sf-guide-tip sf-guide-tip--red">สปาย ชนะ ถ้าเดาสถานที่ถูก ไม่ว่าจะตอนถูกจับหรือประกาศเองก็ตาม</div>
          <div class="sf-guide-tip sf-guide-tip--red">สปาย ชนะ ถ้าหมดเวลาโดยยังไม่โดนจับ</div>
        </div>
      </div>
    </aside>

  </div>

  <!-- ══ VOTING OVERLAY ══════════════════════════════════════════════════════ -->
  <div id="sf-voting" class="sf-overlay hidden">
    <div class="sf-overlay-card">
      <div class="sf-overlay-emoji">🗳️</div>
      <div class="sf-overlay-title">โหวตกล่าวหา</div>
      <div class="sf-accuse-info">
        <span id="sf-accuse-by" class="sf-nametag"></span>
        <span class="sf-accuse-arrow">กล่าวหาว่า</span>
        <span id="sf-accuse-target" class="sf-nametag sf-nametag--target"></span>
        <span class="sf-accuse-arrow">เป็นสปาย</span>
      </div>
      <div class="sf-vote-btns">
        <button id="sf-vote-yes" class="sf-vote-btn sf-vote-btn--yes">✓ ผิดจริง</button>
        <button id="sf-vote-no"  class="sf-vote-btn sf-vote-btn--no">✗ ไม่ใช่</button>
      </div>
      <div id="sf-vote-tally" class="sf-vote-tally"></div>
      <div id="sf-vote-msg"   class="sf-vote-msg"></div>
    </div>
  </div>

  <!-- ══ END OVERLAY ════════════════════════════════════════════════════════ -->
  <div id="sf-end" class="sf-overlay hidden">
    <div class="sf-overlay-card sf-end-card">
      <div id="sf-end-winner" class="sf-end-winner"></div>
      <div id="sf-end-reason" class="sf-end-reason"></div>
      <div class="sf-end-reveal">
        <div class="sf-end-row"><span class="sf-end-lbl">สปาย</span><span id="sf-end-spy"      class="sf-nametag sf-nametag--target"></span></div>
        <div class="sf-end-row"><span class="sf-end-lbl">สถานที่</span><span id="sf-end-location" class="sf-nametag"></span></div>
        <div id="sf-end-guess-row" class="sf-end-row hidden"><span class="sf-end-lbl">สปายเดา</span><span id="sf-end-spy-guess" class="sf-nametag"></span></div>
      </div>
      <div id="sf-end-roles" class="sf-end-roles"></div>
      <button id="sf-new-game-btn" class="sf-new-game-btn hidden">เล่นอีกรอบ</button>
    </div>
  </div>

</div>
<script src="/socket.io/socket.io.js"></script>
<script defer src="/js/spyfall.js?v=3"></script>
</body>
</html>
