<!DOCTYPE html>
<html lang="th">
<head><%- include('../partials/head') %></head>
<body class="auth-body">
<main class="auth-main">
  <div class="auth-card">
    <div class="auth-logo">🌐 VoidSector</div>
    <h1 class="auth-title">ตั้งรหัสผ่านใหม่</h1>

    <% if (error) { %>
      <div class="alert-error"><%= error %></div>
    <% } %>

    <form method="POST" action="/reset-password" class="auth-form">
      <input type="hidden" name="token" value="<%= token %>">
      <div class="form-group">
        <label for="password">รหัสผ่านใหม่</label>
        <input type="password" id="password" name="password" placeholder="อย่างน้อย 6 ตัวอักษร" required autofocus minlength="6">
      </div>
      <div class="form-group">
        <label for="confirm">ยืนยันรหัสผ่าน</label>
        <input type="password" id="confirm" placeholder="พิมพ์รหัสผ่านอีกครั้ง" required minlength="6">
      </div>
      <button type="submit" class="btn-primary btn-full" id="submit-btn">บันทึกรหัสผ่านใหม่</button>
    </form>

    <p class="auth-switch" style="margin-top:16px;"><a href="/login">← กลับไปเข้าสู่ระบบ</a></p>
  </div>
</main>
<script>
document.querySelector('form').addEventListener('submit', function(e) {
  const pw = document.getElementById('password').value;
  const cf = document.getElementById('confirm').value;
  if (pw !== cf) {
    e.preventDefault();
    alert('รหัสผ่านไม่ตรงกัน');
  }
});
</script>
</body>
</html>
