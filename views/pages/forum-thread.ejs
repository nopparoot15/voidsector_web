<!DOCTYPE html>
<html lang="th">
<head><%- include('../partials/head') %>
<link rel="stylesheet" href="/css/forum.css">
</head>
<body>
<%- include('../partials/topbar') %>
<main class="forum-page forum-page--thread">

  <a href="/forum" class="forum-back">← กระทู้ทั้งหมด</a>

  <!-- Thread -->
  <div class="thread-detail">
    <div class="thread-detail-header">
      <h1 class="thread-detail-title"><%= thread.title %></h1>
      <div class="thread-detail-meta">
        <span class="thread-author">@<%= thread.username %></span>
        <span class="thread-dot">·</span>
        <span class="thread-time"><%= thread.timeAgo %></span>
        <span class="thread-dot">·</span>
        <span class="thread-expire-badge <% if (thread.daysLeft <= 3) { %>thread-expire-badge--soon<% } %>">
          ⏳ หมดอายุใน <%= thread.daysLeft %> วัน
        </span>
        <% if (myId && myId === thread.user_id) { %>
          <form method="POST" action="/forum/<%= thread.id %>/delete" style="margin-left:auto" onsubmit="return confirm('ลบกระทู้นี้?')">
            <button type="submit" class="thread-delete-btn">🗑 ลบ</button>
          </form>
        <% } %>
      </div>
    </div>
    <div class="thread-detail-body"><%= thread.body %></div>
    <% if (thread.image) { %>
      <img class="thread-detail-image" src="<%- thread.image %>" alt="รูปประกอบ">
    <% } %>
  </div>

  <!-- Comments -->
  <div id="comments" class="comment-section">
    <div class="comment-section-title">💬 <%= comments.length %> ความคิดเห็น</div>

    <% if (error) { %>
      <div class="forum-error"><%= error %></div>
    <% } %>

    <% comments.forEach(c => { %>
      <div class="comment-card">
        <div class="comment-meta">
          <span class="thread-author">@<%= c.username %></span>
          <span class="thread-dot">·</span>
          <span class="thread-time"><%= c.timeAgo %></span>
        </div>
        <div class="comment-body"><%= c.body %></div>
      </div>
    <% }) %>

    <% if (user && !user.isGuest) { %>
      <form class="comment-form" method="POST" action="/forum/<%= thread.id %>/comment">
        <textarea
          class="comment-form-textarea"
          name="body"
          placeholder="แสดงความคิดเห็น..."
          maxlength="2000"
          rows="3"
          required
        ></textarea>
        <div class="comment-form-actions">
          <button type="submit" class="comment-form-submit">ส่ง →</button>
        </div>
      </form>
    <% } else { %>
      <div class="comment-login-hint">
        <a href="/login">เข้าสู่ระบบ</a> เพื่อแสดงความคิดเห็น
      </div>
    <% } %>
  </div>

</main>
</body>
</html>
