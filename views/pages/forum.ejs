<!DOCTYPE html>
<html lang="th">
<head><%- include('../partials/head') %>
<link rel="stylesheet" href="/css/forum.css">
</head>
<body>
<%- include('../partials/topbar') %>
<main class="forum-page">

  <div class="forum-header">
    <div>
      <h1 class="forum-title">💬 กระทู้</h1>
      <p class="forum-sub">พูดคุย · ถามตอบ · แชร์ความคิดเห็น</p>
    </div>
    <% if (user && !user.isGuest) { %>
      <a href="/forum/new" class="forum-new-btn">✏️ ตั้งกระทู้</a>
    <% } else { %>
      <a href="/login" class="forum-new-btn forum-new-btn--ghost">เข้าสู่ระบบเพื่อตั้งกระทู้</a>
    <% } %>
  </div>

  <% if (threads.length === 0) { %>
    <div class="forum-empty">
      <div class="forum-empty-icon">📭</div>
      <div>ยังไม่มีกระทู้ เป็นคนแรกที่ตั้งกระทู้สิ!</div>
    </div>
  <% } else { %>
    <div class="thread-list">
      <% threads.forEach(t => { %>
        <a href="/forum/<%= t.id %>" class="thread-card">
          <div class="thread-card-main">
            <div class="thread-card-title"><%= t.title %></div>
            <div class="thread-card-meta">
              <span class="thread-author">@<%= t.username %></span>
              <span class="thread-dot">·</span>
              <span class="thread-time"><%= t.timeAgo %></span>
            </div>
          </div>
          <div class="thread-card-stats">
            <span class="thread-comments-badge">💬 <%= t.comment_count %></span>
            <span class="thread-expire-badge <% if (t.daysLeft <= 3) { %>thread-expire-badge--soon<% } %>">
              ⏳ <%= t.daysLeft %> วัน
            </span>
          </div>
        </a>
      <% }) %>
    </div>

    <% if (totalPages > 1) { %>
      <div class="forum-pagination">
        <% if (page > 1) { %>
          <a href="/forum?page=<%= page - 1 %>" class="forum-page-btn">← ก่อนหน้า</a>
        <% } %>
        <span class="forum-page-info"><%= page %> / <%= totalPages %></span>
        <% if (page < totalPages) { %>
          <a href="/forum?page=<%= page + 1 %>" class="forum-page-btn">ถัดไป →</a>
        <% } %>
      </div>
    <% } %>
  <% } %>

</main>
</body>
</html>
