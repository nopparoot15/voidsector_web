<!DOCTYPE html>
<html lang="th">
<head>
  <title>Cyber Portal | Compiler</title>
  <%- include('../partials/head') %>
  <style>
    /* Page chrome (keep within VOIDSECTOR theme) */
    .vs-compiler-wrap{ width:95%; max-width:1400px; }
    .vs-compiler-card{ padding:18px; }
    .vs-compiler-frame{
      width:100%;
      height:min(78vh, 820px);
      border:1px solid rgba(255,0,255,0.28);
      border-radius:16px;
      overflow:hidden;
      box-shadow: 0 18px 60px rgba(0,0,0,0.45);
      background: rgba(0,0,0,0.35);
    }
    .vs-compiler-frame iframe{ width:100%; height:100%; border:0; display:block; background:#0b0f14; }

    /* Modal */
    .vs-modal-backdrop{
      position:fixed; inset:0; z-index:9999;
      background: radial-gradient(1200px 600px at 20% 10%, rgba(0,255,255,0.10), transparent 55%),
                  radial-gradient(900px 500px at 80% 30%, rgba(255,0,255,0.12), transparent 55%),
                  rgba(0,0,0,0.72);
      display:flex; align-items:center; justify-content:center;
      padding:18px;
      backdrop-filter: blur(6px);
    }
    .vs-modal{
      width:min(680px, 100%);
      border-radius:18px;
      border:1px solid rgba(0,255,255,0.22);
      background: linear-gradient(180deg, rgba(10,16,24,0.92), rgba(8,10,14,0.92));
      box-shadow: 0 20px 80px rgba(0,0,0,0.55);
      padding:18px;
    }
    .vs-modal h2{ margin:0; font-family:'Orbitron'; letter-spacing:1px; color:#0ff; text-shadow:0 0 10px rgba(0,255,255,0.35); font-size:18px; }
    .vs-modal p{ margin:10px 0 0; color:#aab6c3; line-height:1.7; font-size:13px; }
    .vs-modal .row{ margin-top:14px; display:flex; gap:10px; flex-wrap:wrap; }
    .vs-select{
      flex:1; min-width:240px;
      background: rgba(0,0,0,0.35);
      color:#e7f6ff;
      border:1px solid rgba(0,255,255,0.20);
      border-radius:12px;
      padding:10px 12px;
      outline:none;
    }
    .vs-btn{
      border-radius:999px;
      padding:10px 14px;
      font-size:12px;
      border:1px solid rgba(0,255,255,0.22);
      background: rgba(255,255,255,0.03);
      color:#9ff;
      cursor:pointer;
      white-space:nowrap;
    }
    .vs-btn.magenta{
      border-color: rgba(255,0,255,0.30);
      color:#ffb3ff;
    }
    .vs-btn.primary{
      background: linear-gradient(90deg, rgba(0,255,255,0.18), rgba(255,0,255,0.14));
      border-color: rgba(0,255,255,0.26);
      color:#eaffff;
    }
    .vs-hint{ margin-top:12px; color:#7f8a97; font-size:12px; line-height:1.6; }
    .vs-hint code{ color:#b7f7ff; }
  </style>
</head>

<body>
  <div class="background"></div>
  <%- include('../partials/topbar') %>

  <div class="container vs-page" style="display:flex; justify-content:center;">
    <div class="card vs-card vs-compiler-wrap">
      <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:12px; flex-wrap:wrap;">
        <div>
          <h1 style="color:#ffb3ff; font-family:'Orbitron'; text-shadow:0 0 10px rgba(255,0,255,0.35); margin:0;">
            🧠 Universal Compiler
          </h1>
          <p style="color:#9aa6b4; margin:10px 0 0; line-height:1.7;">
            ฝัง OneCompiler แบบ <b style="color:#eaffff;">Dark mode</b> • เขียนได้หลายภาษาในหน้าเดียว • รองรับ STDIN (I/O)
          </p>
        </div>

        <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
          <a href="/" class="vs-btn" style="text-decoration:none;">Home</a>
        </div>
      </div>

      <div class="animate-slide-up" style="margin-top:16px;">
        <div class="vs-compiler-frame">
          <!-- src will be injected after language selection -->
          <iframe id="oc-editor" title="OneCompiler Embedded Editor" referrerpolicy="no-referrer"></iframe>
        </div>
        <div class="vs-hint">
          Tip: ถ้าโปรแกรมมี <code>input()</code> / <code>Console.ReadLine()</code> ให้กรอกค่าลงช่อง <b>I/O → STDIN</b> ภายใน compiler ก่อนกด Run (ไม่งั้นจะรอ input แล้ว timeout)
        </div>
      </div>
    </div>
  </div>

  <!-- Language prompt (shown on first entry) -->
  <div id="langModal" class="vs-modal-backdrop" aria-hidden="false">
    <div class="vs-modal" role="dialog" aria-modal="true" aria-labelledby="langTitle">
      <h2 id="langTitle">เลือกภาษาที่จะเริ่มเขียน</h2>
      <p>
        เลือกภาษาเพื่อเริ่มจาก template ที่ถูกต้อง (คุณยังเปลี่ยนภาษาได้ในตัว compiler ภายหลัง)
      </p>

      <div class="row">
        <select id="langSelect" class="vs-select">
          <option value="">— เลือกภาษา —</option>
          <option value="python">Python</option>
          <option value="csharp">C#</option>
          <option value="javascript">JavaScript</option>
          <option value="java">Java</option>
          <option value="cpp">C++</option>
          <option value="c">C</option>
          <option value="go">Go</option>
          <option value="php">PHP</option>
          <option value="ruby">Ruby</option>
        </select>

        <button id="btnStart" class="vs-btn primary" type="button">เริ่มเลย</button>
        <button id="btnSkip" class="vs-btn magenta" type="button">ข้าม (เลือกใน editor)</button>
      </div>

      <div class="vs-hint">
        • ระบบจะโหลด OneCompiler แบบ <code>theme=dark</code> ให้เข้าธีมเว็บ
        <br>
        • ถ้าเลือกภาษาไม่ตรง/ไม่รองรับ ให้กด “ข้าม” แล้วเลือกจากปุ่มภาษาในตัว editor ได้
      </div>
    </div>
  </div>

  <script>
    (function(){
      const modal = document.getElementById('langModal');
      const select = document.getElementById('langSelect');
      const btnStart = document.getElementById('btnStart');
      const btnSkip = document.getElementById('btnSkip');
      const frame = document.getElementById('oc-editor');

      // Build OneCompiler embed URL. See OneCompiler docs: https://onecompiler.com/apis/embed-editor
      function buildSrc(lang){
        const base = lang ? `https://onecompiler.com/embed/${encodeURIComponent(lang)}` : 'https://onecompiler.com/embed/';
        // Keep language switch enabled (user wants one editor for all languages). Dark theme for comfort.
        return `${base}?theme=dark`;
      }

      function openEditor(lang){
        frame.src = buildSrc(lang);
        modal.style.display = 'none';
        modal.setAttribute('aria-hidden', 'true');
      }

      btnStart.addEventListener('click', () => {
        const lang = (select.value || '').trim();
        if (!lang) {
          // If no selection, default to generic editor (user can choose inside)
          openEditor('');
          return;
        }
        openEditor(lang);
      });

      btnSkip.addEventListener('click', () => openEditor(''));

      // UX: Enter key to start
      select.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') btnStart.click();
      });
    })();
  </script>
</body>
</html>
