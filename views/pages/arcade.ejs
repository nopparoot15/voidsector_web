<!DOCTYPE html>
<html lang="th">
<head><%- include('../partials/head') %>
<link rel="stylesheet" href="/css/arcade.css">
</head>
<body>
<%- include('../partials/topbar') %>
<main class="hub-main">
  <div class="section-header">
    <h1>🕹 Arcade</h1>
    <p class="section-sub">เลือกเกม — เล่นคนเดียวหรือชวนเพื่อน</p>
  </div>

  <!-- Solo Games -->
  <div class="section-header" style="margin-top:8px;">
    <h2 style="font-size:22px;">🎯 Solo Play</h2>
    <p class="section-sub">เล่นคนเดียวได้ทันที ไม่ต้องรอเพื่อน</p>
  </div>

  <div class="arcade-grid">

    <div class="arcade-card arcade-card--solo-2048">
      <div class="arcade-card-icon">🔢</div>
      <div class="arcade-card-body">
        <h3>2048</h3>
        <p>เลื่อนกระเบื้องให้รวมกันถึง 2048 — คลาสสิก ติดใจ</p>
        <div class="arcade-badge arcade-badge--solo">1 ผู้เล่น</div>
      </div>
      <a href="/solo/2048" class="arcade-play-btn">เล่นเลย →</a>
    </div>

    <div class="arcade-card arcade-card--solo-snake">
      <div class="arcade-card-icon">🐍</div>
      <div class="arcade-card-body">
        <h3>Snake</h3>
        <p>กินอาหารให้งูยาวที่สุด — อย่าชนกำแพงหรือตัวเอง</p>
        <div class="arcade-badge arcade-badge--solo">1 ผู้เล่น</div>
      </div>
      <a href="/solo/snake" class="arcade-play-btn">เล่นเลย →</a>
    </div>

    <div class="arcade-card arcade-card--solo-memory">
      <div class="arcade-card-icon">🃏</div>
      <div class="arcade-card-body">
        <h3>Memory Match</h3>
        <p>พลิกการ์ดหาคู่ให้ครบก่อนเวลาหมด</p>
        <div class="arcade-badge arcade-badge--solo">1 ผู้เล่น</div>
      </div>
      <a href="/solo/memory" class="arcade-play-btn">เล่นเลย →</a>
    </div>

    <div class="arcade-card arcade-card--solo-breakout">
      <div class="arcade-card-icon">🧱</div>
      <div class="arcade-card-body">
        <h3>Breakout</h3>
        <p>ตีลูกบอลทำลายอิฐ — ยิ่งด่านสูงยิ่งเร็ว</p>
        <div class="arcade-badge arcade-badge--solo">1 ผู้เล่น</div>
      </div>
      <a href="/solo/breakout" class="arcade-play-btn">เล่นเลย →</a>
    </div>

  </div>

  <!-- Multiplayer Games -->
  <div class="section-header" style="margin-top:48px;">
    <h2 style="font-size:22px;">👥 Multiplayer</h2>
    <p class="section-sub">สร้างห้อง — แชร์ลิงก์ — เล่นกับเพื่อน</p>
  </div>

  <div class="arcade-grid">

    <div class="arcade-card arcade-card--xo">
      <div class="arcade-card-icon">⭕</div>
      <div class="arcade-card-body">
        <h3>XO</h3>
        <p>Tic-Tac-Toe 2 คน แบบ realtime</p>
        <div class="arcade-badge">2 ผู้เล่น</div>
      </div>
      <button class="arcade-play-btn" data-game="xo">เล่นเลย →</button>
      <div class="arcade-room-panel hidden" id="panel-xo"></div>
    </div>

    <div class="arcade-card arcade-card--wb">
      <div class="arcade-card-icon">💣</div>
      <div class="arcade-card-body">
        <h3>Word Bomb</h3>
        <p>ต่อคำให้ต่อเนื่อง — ใครหมดชีวิตก่อนแพ้</p>
        <div class="arcade-badge">2–6 ผู้เล่น</div>
      </div>
      <button class="arcade-play-btn" data-game="wordbomb">เล่นเลย →</button>
      <div class="arcade-room-panel hidden" id="panel-wordbomb"></div>
    </div>

    <div class="arcade-card arcade-card--tq">
      <div class="arcade-card-icon">❓</div>
      <div class="arcade-card-body">
        <h3>Trivia Quiz</h3>
        <p>แข่งตอบคำถาม 10 ข้อ — เร็วและถูกได้คะแนนเยอะ</p>
        <div class="arcade-badge">2–8 ผู้เล่น</div>
      </div>
      <button class="arcade-play-btn" data-game="trivia">เล่นเลย →</button>
      <div class="arcade-room-panel hidden" id="panel-trivia"></div>
    </div>

    <div class="arcade-card arcade-card--tr">
      <div class="arcade-card-icon">⌨️</div>
      <div class="arcade-card-body">
        <h3>Typing Race</h3>
        <p>แข่งพิมพ์ประโยค — ใครเร็วที่สุดชนะ</p>
        <div class="arcade-badge">2–6 ผู้เล่น</div>
      </div>
      <button class="arcade-play-btn" data-game="typerace">เล่นเลย →</button>
      <div class="arcade-room-panel hidden" id="panel-typerace"></div>
    </div>

    <div class="arcade-card arcade-card--rps">
      <div class="arcade-card-icon">✊</div>
      <div class="arcade-card-body">
        <h3>Rock Paper Scissors</h3>
        <p>เป่ายิ้งฉุบ realtime — ชนะ 3 รอบก่อนชนะ</p>
        <div class="arcade-badge">2 ผู้เล่น</div>
      </div>
      <button class="arcade-play-btn" data-game="rps">เล่นเลย →</button>
      <div class="arcade-room-panel hidden" id="panel-rps"></div>
    </div>

    <div class="arcade-card arcade-card--dg">
      <div class="arcade-card-icon">🎨</div>
      <div class="arcade-card-body">
        <h3>Draw &amp; Guess</h3>
        <p>ผลัดกันวาดรูปให้เพื่อนทาย — ยิ่งเร็วยิ่งได้คะแนนเยอะ</p>
        <div class="arcade-badge">2–8 ผู้เล่น</div>
      </div>
      <button class="arcade-play-btn" data-game="drawguess">เล่นเลย →</button>
      <div class="arcade-room-panel hidden" id="panel-drawguess"></div>
    </div>

    <div class="arcade-card arcade-card--ck">
      <div class="arcade-card-icon">🏁</div>
      <div class="arcade-card-body">
        <h3>หมากฮอส</h3>
        <p>เดินหมากแนวทแยง — กินให้หมดก่อนชนะ</p>
        <div class="arcade-badge">2 ผู้เล่น</div>
      </div>
      <button class="arcade-play-btn" data-game="checkers">เล่นเลย →</button>
      <div class="arcade-room-panel hidden" id="panel-checkers"></div>
    </div>

    <div class="arcade-card arcade-card--sf">
      <div class="arcade-card-icon">🕵️</div>
      <div class="arcade-card-body">
        <h3>Spyfall</h3>
        <p>1 คนเป็นสปาย ไม่รู้สถานที่ — ช่วยกันจับให้ได้ก่อนหมดเวลา</p>
        <div class="arcade-badge">4–10 ผู้เล่น</div>
      </div>
      <button class="arcade-play-btn" data-game="spyfall">เล่นเลย →</button>
      <div class="arcade-room-panel hidden" id="panel-spyfall"></div>
    </div>

  </div>

  <div id="arcade-creating" class="arcade-creating hidden">
    <span class="arcade-spinner"></span> กำลังสร้างห้อง…
  </div>
</main>

<script>
let activePanel = null;

async function openPanel(btn, game) {
  const panel = document.getElementById(`panel-${game}`);

  // Toggle off if same card clicked again
  if (activePanel === panel && !panel.classList.contains('hidden')) {
    panel.classList.add('hidden');
    btn.classList.remove('active');
    activePanel = null;
    return;
  }

  // Close previous
  if (activePanel) {
    activePanel.classList.add('hidden');
    document.querySelectorAll('.arcade-play-btn.active').forEach(b => b.classList.remove('active'));
  }

  btn.classList.add('active');
  activePanel = panel;
  panel.classList.remove('hidden');
  panel.innerHTML = '<div class="arcade-room-loading"><span class="arcade-spinner"></span> กำลังโหลด…</div>';

  try {
    const r = await fetch(`/arcade/${game}/rooms`);
    const { rooms } = await r.json();
    renderPanel(panel, game, rooms);
  } catch {
    panel.innerHTML = '<div class="arcade-room-error">โหลดไม่ได้ ลองใหม่</div>';
  }
}

function renderPanel(panel, game, rooms) {
  let html = '';
  if (rooms.length > 0) {
    html += '<div class="arcade-room-list">';
    rooms.forEach(room => {
      html += `<div class="arcade-room-item">
        <span class="arcade-room-host">${escHtml(room.host)}</span>
        <span class="arcade-room-count">${room.playerCount} คน</span>
        <button class="arcade-room-join-btn" onclick="joinRoom('${game}','${room.id}')">เข้าร่วม</button>
      </div>`;
    });
    html += '</div>';
  }
  html += `<button class="arcade-create-btn" onclick="createRoom('${game}')">+ สร้างห้องใหม่</button>`;
  panel.innerHTML = html;
}

async function createRoom(game) {
  document.getElementById('arcade-creating').classList.remove('hidden');
  try {
    const r = await fetch(`/arcade/${game}/create`, { method: 'POST' });
    const { roomId } = await r.json();
    window.location.href = `/arcade/${game}/${roomId}`;
  } catch {
    document.getElementById('arcade-creating').classList.add('hidden');
  }
}

function joinRoom(game, roomId) {
  window.location.href = `/arcade/${game}/${roomId}`;
}

function escHtml(s) {
  return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

document.querySelectorAll('.arcade-play-btn').forEach(btn => {
  btn.addEventListener('click', () => openPanel(btn, btn.dataset.game));
});
</script>
</body>
</html>
