<!DOCTYPE html>
<html lang="th">
<head>
  <title>VOIDSECTOR | Learn Hub</title>
  <%- include('../partials/head') %>
</head>
<body>
  <div class="background"></div>
  <%- include('../partials/topbar') %>

  <div class="container vs-page">
    <div class="card vs-card" style="max-width: 980px; margin: 0 auto;">
      <h1 style="color:#0ff; font-family:'Orbitron'; text-shadow:0 0 10px #0ff; text-align:center; margin-top:0;">
        LEARN HUB
      </h1>
      <p style="color:#aaa; text-align:center; margin: 10px auto 18px; max-width: 760px; line-height:1.7;">
        เลือกหมวดหมู่ก่อนเข้า <b style="color:#9ff;">คอร์สทั้งหมด</b> — ในอนาคตจะเพิ่มหมวดใหม่ ๆ ได้ง่าย
      </p>

      <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 14px; margin-top: 16px;">
        <a href="/learn?cat=language" style="text-decoration:none;">
          <div style="border:1px solid rgba(0,255,255,0.22); border-radius:14px; padding:18px;
                      background: linear-gradient(135deg, rgba(0,255,255,0.06), rgba(0,0,0,0.18));
                      transition: 0.2s;">
            <div style="font-size: 30px; margin-bottom: 10px;">🌐</div>
            <div style="color:#0ff; font-family:'Orbitron'; font-size: 15px; margin-bottom: 6px;">ภาษา</div>
            <div style="color:#aaa; font-size: 13px; line-height:1.5;">อังกฤษ/ญี่ปุ่น/อื่น ๆ (เพิ่มได้ในอนาคต)</div>
            <div style="margin-top: 12px; color:#9ff; font-size: 12px;">เลือกหมวดนี้ →</div>
          </div>
        </a>

        <a href="/learn?cat=coding" style="text-decoration:none;">
          <div style="border:1px solid rgba(255,0,255,0.22); border-radius:14px; padding:18px;
                      background: linear-gradient(135deg, rgba(255,0,255,0.06), rgba(0,0,0,0.18));
                      transition: 0.2s;">
            <div style="font-size: 30px; margin-bottom: 10px;">💻</div>
            <div style="color:#ffb3ff; font-family:'Orbitron'; font-size: 15px; margin-bottom: 6px;">Coding</div>
            <div style="color:#aaa; font-size: 13px; line-height:1.5;">Python/JS/อื่น ๆ (เพิ่มได้ในอนาคต)</div>
            <div style="margin-top: 12px; color:#ffb3ff; font-size: 12px;">เลือกหมวดนี้ →</div>
          </div>
        </a>
      </div>

      <div style="margin-top: 16px; text-align:center;">
        <a href="/learn" style="color:#9ff; text-decoration:none; font-size: 12px;">ข้ามไปดูคอร์สทั้งหมด →</a>
      </div>
    </div>
  </div>

  <script defer src="/js/topbar.js"></script>
  <script defer src="/js/chat-dock.js"></script>
</body>
</html>
