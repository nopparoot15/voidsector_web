<!DOCTYPE html>
<html lang="th">
<head><%- include('../partials/head') %></head>
<body>
<%- include('../partials/topbar') %>
<main class="hub-main">
  <div class="section-header">
    <h1>🏆 Leaderboard</h1>
    <p class="section-sub">จัดอันดับตาม XP สะสม — ยิ่งเรียนเยอะ ยิ่งขึ้นอันดับ</p>
  </div>

  <div class="lb-podium" id="lbPodium"></div>

  <div class="lb-card">
    <div class="lb-toolbar">
      <span class="lb-sub-label">อันดับทั้งหมด</span>
      <button id="lbRefresh" class="btn-sm btn-outline">🔄 รีเฟรช</button>
    </div>
    <table class="lb-table">
      <thead>
        <tr>
          <th>#</th>
          <th>ผู้เรียน</th>
          <th>XP</th>
          <th>Streak</th>
          <th>บทเรียน</th>
        </tr>
      </thead>
      <tbody id="lbBody"></tbody>
    </table>
    <div id="lbEmpty" class="lb-empty" style="display:none">ยังไม่มีข้อมูล — ไปเรียนแล้วมาดูอันดับได้เลย 🚀</div>
  </div>
</main>
<script src="/js/leaderboard.js"></script>
</body>
</html>
