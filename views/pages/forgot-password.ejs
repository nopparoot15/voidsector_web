<!DOCTYPE html>
<html lang="th">
<head><%- include('../partials/head') %></head>
<body class="auth-body">
<main class="auth-main">
  <div class="auth-card">
    <div class="auth-logo">🌐 VoidSector</div>
    <h1 class="auth-title">ลืมรหัสผ่าน</h1>

    <% if (error) { %>
      <div class="alert-error"><%= error %></div>
    <% } %>

    <% if (resetUrl) { %>
      <div style="background:rgba(6,182,212,.1);border:1px solid rgba(6,182,212,.3);border-radius:10px;padding:16px;margin-bottom:16px;text-align:center;">
        <p style="color:rgba(235,245,255,.7);font-size:14px;margin-bottom:10px;">ลิงก์ตั้งรหัสผ่านใหม่ของคุณ (หมดอายุใน 15 นาที):</p>
        <a href="<%= resetUrl %>" style="color:#06b6d4;word-break:break-all;font-size:13px;"><%= resetUrl %></a>
        <br><br>
        <a href="<%= resetUrl %>" class="btn-primary" style="display:inline-block;text-decoration:none;margin-top:4px;">ตั้งรหัสผ่านใหม่ →</a>
      </div>
    <% } else if (sent) { %>
      <div style="background:rgba(74,222,128,.1);border:1px solid rgba(74,222,128,.3);border-radius:10px;padding:16px;text-align:center;color:rgba(235,245,255,.8);font-size:14px;">
        ถ้าอีเมลนี้มีในระบบ ลิงก์จะถูกส่งไป กรุณาตรวจสอบ
      </div>
    <% } else { %>
      <p style="color:rgba(235,245,255,.6);font-size:14px;margin-bottom:16px;">กรอกอีเมลที่สมัครไว้ ลิงก์ตั้งรหัสใหม่จะโผล่ที่นี่เลย</p>
      <form method="POST" action="/forgot-password" class="auth-form">
        <div class="form-group">
          <label for="email">อีเมล</label>
          <input type="email" id="email" name="email" placeholder="your@email.com" required autofocus>
        </div>
        <button type="submit" class="btn-primary btn-full">รับลิงก์ตั้งรหัสใหม่</button>
      </form>
    <% } %>

    <p class="auth-switch" style="margin-top:16px;"><a href="/login">← กลับไปเข้าสู่ระบบ</a></p>
  </div>
</main>
</body>
</html>
