<!DOCTYPE html>
<html lang="th">
<head>
  <title>VOIDSECTOR | Watch Party</title>
  <%- include('../partials/head') %>
  <link rel="stylesheet" href="/css/watch-party.css" />
</head>
<body>
  <div class="background"></div>
  <%- include('../partials/topbar') %>

  <div class="wp-shell">
    <div class="wp-card">
      <div class="wp-title">Watch Party</div>
      <div class="wp-sub">สร้างห้องดูคลิปพร้อมกัน • แชร์ลิงก์ให้คนอื่นเข้ามาได้ทันที (ต้องล็อกอินก่อน)</div>

      <div class="wp-row">
        <label class="wp-radio"><input type="radio" name="vis" value="public" checked> Public</label>
        <label class="wp-radio"><input type="radio" name="vis" value="private"> Private</label>
      </div>

      <button class="wp-btn wp-btn--primary" id="wpCreate">Create room</button>

      <div class="wp-note">
        <b>หมายเหตุ:</b> ซิงก์แบบ “ควบคุมได้เต็ม” จะทำได้กับลิงก์ที่ embed/ควบคุมได้ (เช่น YouTube/Vimeo หรือไฟล์ mp4/webm)
        ถ้าเว็บปลายทางกัน iframe (X-Frame-Options/CSP) ระบบจะให้เปิดลิงก์แยกแท็บและใช้การซิงก์เวลาแทน.
      </div>
    </div>
  </div>

  <script>
    (function(){
      const btn = document.getElementById('wpCreate');
      btn.addEventListener('click', async () => {
        btn.disabled = true;
        try {
          const isPublic = (document.querySelector('input[name="vis"]:checked')?.value === 'public');
          const r = await fetch('/api/watch/rooms', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ isPublic })
          });
          const j = await r.json();
          if (!j.ok) throw new Error(j.reason || 'create_failed');
          window.location.href = j.shareUrl;
        } catch (e) {
          alert('สร้างห้องไม่สำเร็จ ลองใหม่อีกครั้ง');
        } finally {
          btn.disabled = false;
        }
      });
    })();
  </script>
</body>
</html>
