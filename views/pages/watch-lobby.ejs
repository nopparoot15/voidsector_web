<!DOCTYPE html>
<html lang="th">
<head>
  <title>VOIDSECTOR | YouTube Watch Party</title>
  <%- include('../partials/head') %>
  <link rel="stylesheet" href="/css/whiteboard.css" />
  <link rel="stylesheet" href="/css/watch-party.css" />
</head>
<body>
  <div class="background"></div>
  <%- include('../partials/topbar') %>

  

  <div class="container vs-page">
    <div class="card vs-card">
      <div class="wb-lobby">
        <div class="wb-lobby__title">
          <h1>YOUTUBE WATCH PARTY</h1>
          <p>ดู YouTube พร้อมกันแบบ realtime • Public/Private • แชร์ลิงก์ชวนเพื่อนได้ทันที</p>
        </div>

        <div class="wb-lobby__grid">
          <a class="wb-card" href="/watch/public">
            <div class="wb-card__icon">🌐</div>
            <div class="wb-card__hdr">ห้องรวม (Public)</div>
            <div class="wb-card__desc">ใครเข้ามาก็ดูร่วมกันได้</div>
            <div class="wb-card__cta">เข้าเลย →</div>
          </a>

          <button class="wb-card wb-card--button" id="wpCreatePrivate" type="button">
            <div class="wb-card__icon">🔒</div>
            <div class="wb-card__hdr">สร้างห้องส่วนตัว</div>
            <div class="wb-card__desc">สร้างลิงก์ห้อง • ชวนเพื่อน • ห้องจะลบเมื่อไม่มีใครอยู่</div>
            <div class="wb-card__cta">สร้างห้อง →</div>
          </button>
        </div>

        <div class="wb-lobby__note">
          <div class="wb-chip">TIP</div>
          <div>ระบบนี้รับเฉพาะลิงก์ YouTube เท่านั้น เพื่อให้ควบคุมและซิงก์ได้เสถียร</div>
        </div>
      </div>
    </div>
  </div>

  <script>
    (function(){
      const btn = document.getElementById('wpCreatePrivate');
      btn.addEventListener('click', async () => {
        btn.disabled = true;
        try {
          const r = await fetch('/api/watch/rooms', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ isPublic: false })
          });
          const j = await r.json();
          if (!j.ok) throw new Error(j.reason || 'create_failed');
          window.location.href = j.shareUrl;
        } catch (e) {
          alert('สร้างห้องไม่สำเร็จ ลองใหม่อีกครั้ง');
        } finally {
          btn.disabled = false;
        }
      });
    })();
  </script>
</body>
</html>
