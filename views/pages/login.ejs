<!DOCTYPE html>
<html lang="th">
<head>
  <title>Cyber Portal | Login</title>
  <%- include('../partials/head') %>
</head>
<body>
  <div class="background"></div>
  <%- include('../partials/topbar') %>

  <div class="container vs-page" style="display:flex; justify-content:center;">
    <div class="modal-content"
         style="display:block; width:100%; max-width: 420px;">

      <h2 style="color:#0ff; font-family:'Orbitron'; margin-top:0; text-align:center;">
        LOGIN
      </h2>

      <!-- ✅ แสดง error (ถ้า auth route ส่งมา) -->
      <% if (typeof error !== 'undefined' && error) { %>
        <div style="margin: 0 0 12px;
                    padding: 10px 12px;
                    border-radius: 10px;
                    border: 1px solid rgba(255,0,255,0.35);
                    background: rgba(255,0,255,0.08);
                    color: #ffb3ff;
                    font-size: 12px;
                    line-height: 1.5;">
          <%= error %>
        </div>
      <% } %>

      <!-- ✅ FORM LOGIN -->
      <form method="post" action="/login">
        <input
          type="text"
          name="username"
          placeholder="USERNAME"
          required
          autocomplete="username"
          style="width:100%; box-sizing:border-box;" />

        <input
          type="password"
          name="password"
          placeholder="PASSWORD"
          required
          autocomplete="current-password"
          style="width:100%; box-sizing:border-box;" />

        <!-- 🔹 ลิงก์ลืมรหัสผ่าน -->
        <div style="text-align:right; margin: -6px 0 12px;">
          <a href="/forgot-password"
             style="color:#0ff; font-size:12px; text-decoration:underline;">
            ลืมรหัสผ่าน?
          </a>
        </div>

        <button
          type="submit"
          class="btn-cyber"
          style="width:100%;
                 padding:12px;
                 background:#0ff;
                 color:#000;
                 font-weight:bold;
                 border:none;
                 margin-bottom: 12px;">
          SIGN IN
        </button>
      </form>

      <div style="display:flex; justify-content:space-between; gap:10px;">
        <a href="/register"
           style="color:#f0f; text-decoration:underline; font-size: 12px;">
          สมัครสมาชิก
        </a>
        <a href="/"
           style="color:#777; text-decoration:underline; font-size: 12px;">
          กลับหน้าแรก
        </a>
      </div>

    </div>
  </div>
</body>
</html>
