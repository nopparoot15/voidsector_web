<!DOCTYPE html>
<html lang="th">
<head><%- include('../partials/head') %></head>
<body class="auth-body">
<%- include('../partials/topbar') %>
<main class="auth-main">
  <div class="auth-card">
    <div class="auth-logo">🌐 LinguaVoid</div>
    <h1 class="auth-title">เข้าสู่ระบบ</h1>
    <% if (error) { %>
      <div class="alert-error"><%= error %></div>
    <% } %>
    <form method="POST" action="/auth/login" class="auth-form">
      <div class="form-group">
        <label for="email">อีเมล</label>
        <input type="email" id="email" name="email" placeholder="your@email.com" required autocomplete="email">
      </div>
      <div class="form-group">
        <label for="password">รหัสผ่าน</label>
        <input type="password" id="password" name="password" placeholder="••••••••" required autocomplete="current-password">
      </div>
      <button type="submit" class="btn-primary btn-full">เข้าสู่ระบบ</button>
    </form>
    <p class="auth-switch">ยังไม่มีบัญชี? <a href="/register">สมัครสมาชิกฟรี</a></p>
  </div>
</main>
</body>
</html>
