<!DOCTYPE html>
<html lang="th">
<head>
  <title>VOIDSECTOR | Direct Message</title>
  <%- include('../partials/head') %>
  <link rel="stylesheet" href="/css/dm.css" />
</head>

<body>
  <div class="background"></div>
  <%- include('../partials/topbar') %>

  <div class="container vs-page">
    <div class="dm-wrap">
      <div class="card vs-card dm-shell">
        <div class="dm-head">
          <div>
            <div class="title">💬 Direct Message</div>
            <div class="sub">VOIDSECTOR secure channel</div>
          </div>
          
        </div>

        <div id="messages" class="dm-messages" aria-live="polite"></div>

        <div class="dm-input">
          <input id="messageInput" placeholder="พิมพ์ข้อความ..." autocomplete="off" />
          <button id="sendBtn" class="dm-send">Send</button>
        </div>
      </div>
    </div>
  </div>

  <!-- socket.io -->
  <script src="/socket.io/socket.io.js"></script>

  <!-- expose data from server -->
  <script>
    window.__DM__ = {
      me: {
        id: <%- JSON.stringify(user.id) %>,
        username: <%- JSON.stringify(user.username) %>
      },
      friendId: <%- JSON.stringify(friendId) %>
    };
  </script>

  <!-- dm logic -->
  <script src="/js/dm-page.js"></script>
</body>
</html>
