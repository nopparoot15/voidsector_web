<!DOCTYPE html>
<html lang="th">
<head><%- include('../partials/head') %></head>
<body class="lesson-body">

<div id="lesson-container" data-lesson-id="<%= lessonId %>" data-lang-code="<%= langCode %>">

  <div id="lesson-header">
    <button id="exit-btn" class="exit-btn">✕</button>
    <div id="progress-bar-wrap">
      <div id="progress-bar"></div>
    </div>
    <span id="progress-text">0 / 0</span>
  </div>

  <!-- ─── INTRO SCREEN ────────────────────────────────────────────── -->
  <div id="intro-screen" class="hidden">
    <div class="intro-card">
      <h2 id="intro-lesson-title">กำลังโหลด...</h2>
      <p class="intro-sub">ศึกษาไวยากรณ์และคำศัพท์ก่อนเริ่มทำแบบฝึกหัด</p>

      <div id="grammar-note-section" class="intro-note-section hidden">
        <div class="intro-note-header">ไวยากรณ์สำคัญ</div>
        <div id="grammar-note-text" class="intro-note-body"></div>
      </div>

      <div id="cultural-note-section" class="intro-note-section hidden">
        <div class="intro-note-header">Cultural Note</div>
        <div id="cultural-note-text" class="intro-note-body intro-note-cultural"></div>
      </div>

      <div class="vocab-section">
        <div class="vocab-section-hdr">คำศัพท์ในบทนี้</div>
        <table class="vocab-table">
          <thead>
            <tr>
              <th>คำ / วลี</th>
              <th id="reading-th">การอ่าน</th>
              <th>ความหมาย</th>
            </tr>
          </thead>
          <tbody id="vocab-table-body"></tbody>
        </table>
      </div>

      <button id="start-exercises-btn" class="btn-primary btn-lg">เริ่มเลย →</button>
    </div>
  </div>

  <!-- ─── FLASHCARD SCREEN ─────────────────────────────────────────── -->
  <div id="flashcard-screen" class="hidden">
    <div class="fc-topbar">
      <button id="fc-skip-btn" class="fc-skip">ข้ามไปทำแบบฝึกหัด</button>
    </div>
    <div class="fc-main">
      <div class="fc-meta">
        <span id="fc-counter" class="fc-counter"></span>
        <div class="fc-prog-wrap"><div class="fc-prog-bar" id="fc-prog-bar"></div></div>
      </div>
      <div class="fc-card" id="fc-card">
        <div class="fc-lang" id="fc-lang-label"></div>
        <div class="fc-word" id="fc-word"></div>
        <div class="fc-reading" id="fc-reading"></div>
        <div class="fc-divider hidden" id="fc-divider"></div>
        <div class="fc-meaning hidden" id="fc-meaning"></div>
      </div>
      <div class="fc-actions">
        <button id="fc-reveal-btn" class="btn-outline fc-btn">ดูความหมาย</button>
        <button id="fc-next-btn" class="btn-primary fc-btn hidden">ถัดไป →</button>
        <button id="fc-done-btn" class="btn-primary fc-btn hidden">เริ่มทำแบบฝึกหัด →</button>
      </div>
      <div class="fc-tip" id="fc-tip"></div>
    </div>
  </div>

  <!-- ─── EXERCISE AREA ────────────────────────────────────────────── -->
  <div id="exercise-area" class="hidden">
    <div id="exercise-card"></div>
    <div id="answer-area"></div>

    <div id="check-bar">
      <button id="check-btn" disabled>ตรวจคำตอบ</button>
    </div>

    <div id="feedback-panel">
      <div id="feedback-header"></div>
      <div id="feedback-body"></div>
      <button id="continue-btn">ถัดไป →</button>
    </div>
  </div>

</div>

<!-- ─── COMPLETION SCREEN ─────────────────────────────────────────── -->
<div id="completion-screen" class="hidden">
  <div class="completion-card">
    <div class="completion-star">★</div>
    <h2>เยี่ยมมาก!</h2>
    <div class="completion-stats">
      <div class="completion-stat" id="result-score"></div>
      <div class="completion-stat" id="result-pct"></div>
      <div class="completion-stat highlight" id="result-xp"></div>
      <div class="completion-stat" id="result-streak"></div>
      <div class="completion-stat" id="result-level"></div>
    </div>
    <a id="back-learn-btn" href="/learn/<%= langCode %>" class="btn-primary btn-lg">กลับไปเรียน</a>
  </div>
</div>

<script src="/js/lesson.js"></script>
</body>
</html>
