<!DOCTYPE html>
<html lang="th">
<head><%- include('../partials/head') %>
<link rel="stylesheet" href="/css/calculator.css" />
</head>
<body>
<%- include('../partials/topbar') %>
<main class="vs-page">
  <section class="vs-card vs-calc">
    <h1 class="vs-calc__title">🧮 Calculator</h1>
    <div class="vs-calc__row">
      <input id="expr" class="vs-input" type="text" placeholder="e.g. (2+3)*sin(pi/4) + sqrt(2)" autocomplete="off">
      <button id="run" class="vs-btn" type="button">=</button>
    </div>
    <pre id="out" class="vs-calc__out"></pre>
    <div id="hist" class="vs-calc__hist"></div>
    <p class="vs-calc__hint">รองรับ: +−×÷ sin cos tan sqrt log pi e factorial กด Enter หรือ = เพื่อคำนวณ</p>
  </section>
</main>
<script src="https://cdnjs.cloudflare.com/ajax/libs/mathjs/12.4.3/math.min.js" crossorigin="anonymous"></script>
<script defer src="/js/calculator.js"></script>
</body>
</html>
