<!DOCTYPE html>
<html lang="th">
<head><%- include('../partials/head') %>
<link rel="stylesheet" href="/css/calculator.css" />
</head>
<body>
<%- include('../partials/topbar') %>
<main class="calc-main">
  <div class="calc-wrap">

    <!-- Display -->
    <div class="calc-display">
      <div class="calc-expr-line" id="calc-expr-line"></div>
      <div class="calc-main-line" id="calc-main-line">0</div>
    </div>

    <!-- History -->
    <div class="calc-hist" id="calc-hist"></div>

    <!-- Buttons -->
    <div class="calc-grid">
      <!-- Scientific row 1 -->
      <button class="cb cb-fn" data-action="sin(">sin</button>
      <button class="cb cb-fn" data-action="cos(">cos</button>
      <button class="cb cb-fn" data-action="tan(">tan</button>
      <button class="cb cb-fn" data-action="sqrt(">√</button>
      <!-- Scientific row 2 -->
      <button class="cb cb-fn" data-action="log10(">log</button>
      <button class="cb cb-fn" data-action="log(">ln</button>
      <button class="cb cb-fn" data-action="^2">x²</button>
      <button class="cb cb-fn" data-action="^">xʸ</button>
      <!-- Constants & parens -->
      <button class="cb cb-const" data-action="pi">π</button>
      <button class="cb cb-const" data-action="e">e</button>
      <button class="cb cb-paren" data-action="(">(</button>
      <button class="cb cb-paren" data-action=")">)</button>
      <!-- Row: C del % ÷ -->
      <button class="cb cb-clear" data-action="clear">C</button>
      <button class="cb cb-del"   data-action="del">⌫</button>
      <button class="cb cb-mod"   data-action="%">%</button>
      <button class="cb cb-op"    data-action="÷">÷</button>
      <!-- Row 7 8 9 × -->
      <button class="cb cb-num" data-action="7">7</button>
      <button class="cb cb-num" data-action="8">8</button>
      <button class="cb cb-num" data-action="9">9</button>
      <button class="cb cb-op"  data-action="×">×</button>
      <!-- Row 4 5 6 − -->
      <button class="cb cb-num" data-action="4">4</button>
      <button class="cb cb-num" data-action="5">5</button>
      <button class="cb cb-num" data-action="6">6</button>
      <button class="cb cb-op"  data-action="−">−</button>
      <!-- Row 1 2 3 + -->
      <button class="cb cb-num" data-action="1">1</button>
      <button class="cb cb-num" data-action="2">2</button>
      <button class="cb cb-num" data-action="3">3</button>
      <button class="cb cb-op"  data-action="+">+</button>
      <!-- Row ± 0 . = -->
      <button class="cb cb-neg" data-action="negate">±</button>
      <button class="cb cb-num" data-action="0">0</button>
      <button class="cb cb-num" data-action=".">.</button>
      <button class="cb cb-eq"  data-action="eval">=</button>
    </div>

  </div>
</main>
<script src="https://cdnjs.cloudflare.com/ajax/libs/mathjs/12.4.3/math.min.js" crossorigin="anonymous"></script>
<script defer src="/js/calculator.js"></script>
</body>
</html>
