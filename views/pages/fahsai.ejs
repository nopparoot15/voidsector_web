<!DOCTYPE html>
<html lang="th">
<head>
  <title>ฟ้าใส AI | VOIDSECTOR</title>
  <%- include('../partials/head') %>
  <style>
    /* ── Layout ── */
    .fs-wrap {
      display: flex;
      height: calc(100vh - 56px);
      max-width: 900px;
      margin: 0 auto;
      gap: 0;
    }

    /* ── Sidebar ── */
    .fs-sidebar {
      width: 180px;
      flex-shrink: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 24px 12px;
      border-right: 1px solid rgba(0,255,255,0.1);
      gap: 10px;
    }
    .fs-avatar {
      width: 120px;
      height: 120px;
      border-radius: 16px;
      background: rgba(255,180,100,0.08);
      border: 1px solid rgba(255,180,100,0.25);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 52px;
      overflow: hidden;
    }
    .fs-avatar img { width: 100%; height: 100%; object-fit: cover; border-radius: 16px; }
    .fs-name {
      font-family: 'Orbitron', sans-serif;
      font-size: 13px;
      color: #f2e0a0;
      letter-spacing: 0.5px;
    }
    .fs-status {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 12px;
      color: #888;
    }
    .fs-dot {
      width: 8px; height: 8px;
      border-radius: 50%;
      background: #444;
      transition: background 0.4s;
    }
    .fs-dot.online { background: #22c55e; box-shadow: 0 0 6px #22c55e88; }
    .fs-dot.thinking { background: #f59e0b; box-shadow: 0 0 6px #f59e0b88; animation: pulse 1s infinite; }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }

    .fs-clear-btn {
      margin-top: auto;
      background: rgba(90,20,20,0.6);
      border: 1px solid rgba(255,60,60,0.25);
      color: #ff8888;
      border-radius: 8px;
      padding: 7px 14px;
      font-size: 12px;
      cursor: pointer;
      transition: background 0.2s;
    }
    .fs-clear-btn:hover { background: rgba(140,30,30,0.7); }

    /* ── Chat area ── */
    .fs-main {
      flex: 1;
      display: flex;
      flex-direction: column;
      min-width: 0;
    }
    .fs-messages {
      flex: 1;
      overflow-y: auto;
      padding: 20px 16px;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .fs-messages::-webkit-scrollbar { width: 4px; }
    .fs-messages::-webkit-scrollbar-thumb { background: rgba(0,255,255,0.18); border-radius: 4px; }

    /* Bubbles */
    .fs-bubble-wrap {
      display: flex;
      gap: 8px;
      max-width: 80%;
    }
    .fs-bubble-wrap.user { align-self: flex-end; flex-direction: row-reverse; }
    .fs-bubble-wrap.bot  { align-self: flex-start; }

    .fs-bubble {
      padding: 10px 14px;
      border-radius: 14px;
      font-size: 14px;
      line-height: 1.65;
      word-break: break-word;
      white-space: pre-wrap;
    }
    .fs-bubble.user {
      background: #1d4ed8;
      color: #e0f2fe;
      border-bottom-right-radius: 4px;
    }
    .fs-bubble.bot {
      background: rgba(242,224,160,0.12);
      color: #f2e0a0;
      border: 1px solid rgba(242,224,160,0.2);
      border-bottom-left-radius: 4px;
    }
    .fs-cursor {
      display: inline-block;
      width: 2px; height: 1em;
      background: #f2e0a0;
      margin-left: 2px;
      vertical-align: text-bottom;
      animation: blink 0.8s infinite;
    }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }

    /* Offline banner */
    .fs-offline {
      margin: 12px 16px;
      padding: 10px 14px;
      border-radius: 10px;
      background: rgba(245,158,11,0.1);
      border: 1px solid rgba(245,158,11,0.3);
      color: #fbbf24;
      font-size: 13px;
      line-height: 1.6;
    }

    /* ── Input bar ── */
    .fs-inputbar {
      padding: 12px 16px;
      border-top: 1px solid rgba(0,255,255,0.1);
      display: flex;
      gap: 10px;
      align-items: center;
    }
    .fs-input {
      flex: 1;
      background: rgba(36,20,8,0.8);
      border: 1px solid rgba(122,80,24,0.5);
      border-radius: 24px;
      padding: 10px 18px;
      color: #f0e0b0;
      font-size: 14px;
      font-family: 'Oxanium', sans-serif;
      outline: none;
      transition: border-color 0.2s;
    }
    .fs-input:focus { border-color: rgba(232,184,56,0.7); }
    .fs-input::placeholder { color: #5a4020; }
    .fs-send {
      width: 44px; height: 44px;
      border-radius: 50%;
      background: #e8b838;
      border: none;
      color: #1a0e04;
      font-size: 18px;
      cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      transition: background 0.2s, transform 0.1s;
      flex-shrink: 0;
    }
    .fs-send:hover { background: #c8a020; }
    .fs-send:active { transform: scale(0.93); }
    .fs-send:disabled { background: #4a4a2a; color: #666; cursor: not-allowed; }

    @media (max-width: 600px) {
      .fs-sidebar { display: none; }
    }
  </style>
</head>
<body>
  <div class="background"></div>
  <%- include('../partials/topbar') %>

  <div class="fs-wrap">
    <!-- Sidebar -->
    <div class="fs-sidebar">
      <div class="fs-avatar">
        <img src="/fahsai-avatar.png" alt="" onerror="this.style.display='none';this.parentElement.textContent='🌸'" />
      </div>
      <div class="fs-name">ฟ้าใส</div>
      <div class="fs-status">
        <div class="fs-dot" id="fsDot"></div>
        <span id="fsStatusText">กำลังเชื่อมต่อ...</span>
      </div>
      <button class="fs-clear-btn" id="fsClearBtn">ลบแชท</button>
    </div>

    <!-- Main chat -->
    <div class="fs-main">
      <% if (!online) { %>
      <div class="fs-offline">
        ⚠️ <b>FAHSAI_API_URL ยังไม่ได้ตั้งค่า</b><br>
        เปิด Fahsai บนคอมแล้วรัน <code>tunnel.bat</code> จากนั้น copy URL ไปใส่ใน Railway env var <code>FAHSAI_API_URL</code>
      </div>
      <% } %>

      <div class="fs-messages" id="fsMessages">
        <!-- messages injected here -->
      </div>

      <div class="fs-inputbar">
        <input class="fs-input" id="fsInput" type="text"
               placeholder="พิมพ์ข้อความถึงฟ้าใส…" autocomplete="off" maxlength="2000" />
        <button class="fs-send" id="fsSendBtn" title="ส่ง">▲</button>
      </div>
    </div>
  </div>

  <script>
  (() => {
    const messagesEl = document.getElementById('fsMessages');
    const inputEl    = document.getElementById('fsInput');
    const sendBtn    = document.getElementById('fsSendBtn');
    const dot        = document.getElementById('fsDot');
    const statusText = document.getElementById('fsStatusText');
    const clearBtn   = document.getElementById('fsClearBtn');

    let history = [];   // [{role:'user',content:''},{role:'assistant',content:''}]
    let busy    = false;

    // ── Status polling ──
    const checkStatus = async () => {
      try {
        const r = await fetch('/api/fahsai/status');
        const d = await r.json();
        if (d.online) {
          dot.className = 'fs-dot online';
          statusText.textContent = 'ออนไลน์';
        } else {
          dot.className = 'fs-dot';
          statusText.textContent = d.reason || 'ออฟไลน์';
        }
      } catch {
        dot.className = 'fs-dot';
        statusText.textContent = 'ออฟไลน์';
      }
    };
    checkStatus();
    setInterval(checkStatus, 15000);

    // ── Render helpers ──
    const addBubble = (role, text = '') => {
      const wrap = document.createElement('div');
      wrap.className = `fs-bubble-wrap ${role}`;
      const bbl = document.createElement('div');
      bbl.className = `fs-bubble ${role}`;
      bbl.textContent = text;
      wrap.appendChild(bbl);
      messagesEl.appendChild(wrap);
      messagesEl.scrollTop = messagesEl.scrollHeight;
      return bbl;
    };

    const setUI = (on) => {
      busy = !on;
      sendBtn.disabled = !on;
      inputEl.disabled = !on;
      if (on) {
        sendBtn.textContent = '▲';
        sendBtn.style.background = '#e8b838';
        dot.className = 'fs-dot online';
        statusText.textContent = 'ออนไลน์';
      } else {
        sendBtn.textContent = '◼';
        sendBtn.style.background = '#8b2020';
        dot.className = 'fs-dot thinking';
        statusText.textContent = 'กำลังคิด…';
      }
    };

    // ── Send ──
    const send = async () => {
      if (busy) return;
      const msg = inputEl.value.trim();
      if (!msg) return;

      inputEl.value = '';
      addBubble('user', msg);
      setUI(false);

      const botBubble = addBubble('bot', '');
      const cursor = document.createElement('span');
      cursor.className = 'fs-cursor';
      botBubble.appendChild(cursor);

      let botText = '';

      try {
        const resp = await fetch('/api/fahsai/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ message: msg, history }),
        });

        if (!resp.ok) {
          const err = await resp.json().catch(() => ({}));
          cursor.remove();
          botBubble.textContent = err.error || 'เกิดข้อผิดพลาด ลองใหม่อีกครั้ง';
          setUI(true);
          inputEl.focus();
          return;
        }

        const reader = resp.body.getReader();
        const decoder = new TextDecoder();
        let buf = '';

        while (true) {
          const { done, value } = await reader.read();
          if (done) break;
          buf += decoder.decode(value, { stream: true });

          const lines = buf.split('\n');
          buf = lines.pop();

          for (const line of lines) {
            if (!line.startsWith('data: ')) continue;
            try {
              const data = JSON.parse(line.slice(6));
              if (data.token) {
                botText += data.token;
                const display = botText
                  .replace(/<think>[\s\S]*?<\/think>/g, '')
                  .replace(/<think>[\s\S]*/g, '')
                  .trim();
                botBubble.textContent = display;
                botBubble.appendChild(cursor);
                messagesEl.scrollTop = messagesEl.scrollHeight;
              }
              if (data.done) botText = data.text || botText;
              if (data.error) botBubble.textContent = 'Error: ' + data.error;
            } catch { /* ignore malformed line */ }
          }
        }

      } catch (e) {
        botBubble.textContent = 'เชื่อมต่อไม่ได้ — ตรวจสอบว่า Fahsai เปิดอยู่และ tunnel กำลังทำงาน';
      } finally {
        cursor.remove();
        const finalText = botText.replace(/<think>[\s\S]*?<\/think>/g, '').trim() || botBubble.textContent;
        if (finalText) {
          history.push({ role: 'user', content: msg });
          history.push({ role: 'assistant', content: finalText });
          if (history.length > 40) history = history.slice(-40);
        }
        setUI(true);
        inputEl.focus();
      }
    };

    sendBtn.addEventListener('click', send);
    inputEl.addEventListener('keydown', e => { if (e.key === 'Enter' && !e.shiftKey) send(); });

    clearBtn.addEventListener('click', () => {
      history = [];
      messagesEl.innerHTML = '';
    });

    inputEl.focus();
  })();
  </script>
</body>
</html>
