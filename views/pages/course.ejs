<!DOCTYPE html>
<html lang="th">
<head>
  <title>Cyber Portal | <%= item.title %></title>
  <%- include('../partials/head') %>

  <style>
    .quiz-item-container {
      border: 1px solid #333;
      transition: 0.3s;
      margin-bottom: 20px;
      padding: 15px;
      border-radius: 8px;
    }
    .feedback {
      margin-top: 10px;
      color: #0f0;
      font-size: 0.85rem;
      font-weight: bold;
    }
    #epButtons {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(70px, 1fr));
      gap: 10px;
      margin-bottom: 30px;
      padding: 15px;
      background: rgba(0, 255, 255, 0.05);
      border-radius: 10px;
      border: 1px solid rgba(0, 255, 255, 0.1);
    }
    .btn-ep {
      padding: 10px 5px;
      background: rgba(0, 0, 0, 0.5);
      border: 1px solid #333;
      color: #888;
      cursor: pointer;
      font-family: 'Orbitron';
      font-size: 0.9rem;
      border-radius: 4px;
      transition: all 0.2s;
      text-align: center;
    }
    .btn-ep:hover {
      border-color: #0ff;
      color: #0ff;
      transform: translateY(-2px);
    }
    .btn-ep.active {
      background: #0ff;
      color: #000;
      border-color: #0ff;
      box-shadow: 0 0 10px #0ff;
      font-weight: bold;
    }
  </style>
</head>

<body>
  <div class="background"></div>
  <%- include('../partials/topbar') %>

  <div class="container vs-page">

    <div class="card vs-card">

      <!-- HEADER -->
      <h1 style="color:#0ff;
                 font-family:'Orbitron';
                 text-shadow:0 0 10px #0ff;
                 text-align:center;
                 margin-top:0;">
        <%= item.title %>
      </h1>

      <p style="color:#ccc;
                text-align:center;
                margin-top:-5px;
                margin-bottom:22px;">
        <%= item.desc %>
      </p>

      <!-- EPISODE BUTTONS -->
      <div id="epButtons"></div>

      <!-- MAIN CONTENT -->
      <div style="display:grid;
                  grid-template-columns: 1.5fr 1fr;
                  gap: 25px;
                  text-align:left;">

        <!-- LEFT: VIDEO -->
        <div>
          <div style="position: relative;
                      padding-bottom: 56.25%;
                      height: 0;
                      border: 2px solid #f0f;
                      border-radius: 8px;
                      overflow: hidden;
                      background: #000;">
            <iframe
              id="mainVideo"
              style="position:absolute; top:0; left:0; width:100%; height:100%;"
              src=""
              frameborder="0"
              allowfullscreen>
            </iframe>
          </div>

          <h2 id="courseTitle"
              style="color:#0ff;
                     margin-top: 20px;
                     font-family:'Orbitron';
                     font-size: 1.2rem;">
          </h2>

          <p id="courseDesc"
             style="color:#ccc; line-height:1.5;">
          </p>
        </div>

        <!-- RIGHT: QUIZ -->
        <div id="quizSection"
             style="max-height: 600px;
                    overflow-y:auto;
                    padding-right: 15px;
                    background: rgba(255,255,255,0.03);
                    padding: 20px;
                    border-radius: 10px;">

          <h3 style="color:#f0f;
                     border-bottom: 1px solid #f0f;
                     padding-bottom: 10px;
                     margin-top:0;">
            MISSION: QUIZ
          </h3>

          <div id="quizContainer"></div>

          <button id="submitBtn"
                  class="btn-cyber"
                  style="width:100%;
                         padding: 15px;
                         margin-top: 20px;
                         border: 2px solid #0ff;
                         color: #0ff;
                         font-weight: bold;
                         background: transparent;
                         cursor: pointer;">
            SUBMIT ANSWERS
          </button>
        </div>

      </div>

      <!-- FOOTER ACTION -->
      <div style="margin-top:22px; text-align:center;">
        <a href="/learn"
           style="text-decoration:none;
                  border-radius:999px;
                  padding:8px 14px;
                  font-size:12px;
                  border:1px solid rgba(0,255,255,0.22);
                  background: rgba(255,255,255,0.02);
                  color:#9ff;">
          ⟵ กลับไปหน้าคอร์สทั้งหมด
        </a>
      </div>

    </div>
  </div>

  <!-- expose category for JS -->
  <script>
    window.__COURSE_CATEGORY__ = "<%= category %>";
  </script>
  <script src="/js/course.js" defer></script>
</body>
</html>
