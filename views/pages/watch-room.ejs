<!DOCTYPE html>
<html lang="th">
<head>
  <title>VOIDSECTOR | Watch Party Room</title>
  <%- include('../partials/head') %>
  <link rel="stylesheet" href="/css/watch-party.css" />
</head>
<body>
  <div class="background"></div>
  <%- include('../partials/topbar') %>

  <div class="wp-shell">
    <div class="wp-top">
      <div class="wp-top__left">
        <a class="wp-back" href="/watch">← Lobby</a>
        <div class="wp-meta">
          <div class="wp-meta__title"><%= isPublic ? 'Public Room' : 'Private Room' %></div>
          <div class="wp-meta__sub">room: <span class="wp-mono"><%= roomId %></span> • online: <span id="wpOnline">0</span></div>
        </div>
      </div>
      <% if (isPublic) { %>
      <div class="wp-top__right">
        <input class="wp-input" id="wpShare" readonly value="" />
        <button class="wp-btn" id="wpCopy">Copy</button>
      </div>
      <% } %>
    </div>

    <div class="wp-body">
      <div class="wp-playerCard">
        <div class="wp-row">
          <input class="wp-input" id="wpUrl" placeholder="วางลิงก์คลิป (YouTube/Vimeo/mp4/webm หรือเว็บที่ embed ได้)" />
          <button class="wp-btn wp-btn--primary" id="wpSet">Set</button>
        </div>
        <div class="wp-player-wrap" id="wpPlayerWrap">
          <div class="wp-player" id="wpPlayer"></div>
          <button id="wpTapToggle" class="wp-tap-toggle" type="button" aria-label="Play/Pause"></button>
          <div id="wpCenterIcon" class="wp-center-icon" aria-hidden="true"></div>
        </div>
        <div class="wp-unlock" id="wpUnlock" style="display:none">
          <div class="wp-unlock__title">แตะหนึ่งครั้งเพื่อเริ่มเล่น (ปลดล็อก Autoplay)</div>
          <button class="wp-btn wp-btn--primary" id="wpUnlockBtn">Play & Sync</button>
        </div>
        <div class="wp-controls" id="wpControls" style="display:none">
          <button class="wp-btn" id="wpPlay">Play</button>
          <button class="wp-btn" id="wpPause">Pause</button>
          <button class="wp-btn" id="wpSync">Sync</button>
          <span class="wp-hint">(ซิงก์จะปรับเวลาตามเจ้าห้อง/สถานะล่าสุด)</span>
          <div class="wp-scrub" id="wpScrubWrap" style="display:none">
            <span class="wp-time" id="wpTimeCur">0:00</span>
            <input type="range" min="0" max="1000" value="0" id="wpScrub" class="wp-scrub__range" />
            <span class="wp-time" id="wpTimeDur">0:00</span>
          </div>
        </div>
      </div>

      <% if (!isPublic) { %>
      <aside class="wp-side">
        <div class="wp-side__card">
          <div class="wp-side__hdr">Invite friends</div>
          <div class="wp-side__desc">เลือกเพื่อนแล้วกด Invite • คนที่ถูกเชิญจะเข้าห้องนี้ได้</div>
          <div id="wpFriends" class="wp-friends">Loading...</div>
          <button class="wp-btn wp-btn--primary" id="wpInvite">Invite</button>
        </div>

        <div class="wp-side__card">
          <div class="wp-side__hdr">Share link</div>
          <div class="wp-side__desc">ส่งลิงก์นี้ให้ใครก็ได้ • กดเข้าได้เลย (ต้องล็อกอินก่อน)</div>
          <input class="wp-input" id="wpShare" readonly value="" />
          <button class="wp-btn" id="wpCopy">Copy</button>
        </div>
      </aside>
      <% } %>
    </div>
  </div>

  <script>
    window.WP_ROOM_ID = <%- JSON.stringify(roomId) %>;
    window.WP_IS_PUBLIC = <%- JSON.stringify(!!isPublic) %>;
    window.WP_JOIN_KEY = <%- JSON.stringify(typeof joinKey !== 'undefined' ? (joinKey || '') : '') %>;
  </script>
  <script defer src="/js/watch-party.js"></script>
</body>
</html>
