<header class="topbar">
  <a href="/" class="logo">⬡ VoidSector</a>
  <nav class="topbar-nav">
    <a href="/languages" class="nav-link">🌐 ภาษา</a>
    <a href="/coding" class="nav-link">💻 Coding</a>
    <a href="/games" class="nav-link">🎮 เกม</a>
    <a href="/music" class="nav-link">🎵 ดนตรี</a>
  </nav>
  <div class="topbar-right">
    <% if (user) { %>
      <span class="streak-badge">🔥 <%= user.streak || 0 %></span>
      <span class="xp-badge">⚡ <%= user.xp || 0 %></span>
      <a href="/profile" class="nav-link user-link"><%= user.username %></a>
      <a href="/logout" class="btn-outline btn-sm">ออก</a>
    <% } else { %>
      <a href="/login" class="btn-outline btn-sm">เข้าสู่ระบบ</a>
      <a href="/register" class="btn-primary btn-sm">สมัคร</a>
    <% } %>
  </div>
</header>
