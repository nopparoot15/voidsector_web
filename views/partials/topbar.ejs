<header class="topbar">
  <div class="topbar-left">
    <a href="/" class="logo">🌐 LinguaVoid</a>
  </div>
  <nav class="topbar-nav">
    <% if (user) { %>
      <a href="/home" class="nav-link">หน้าแรก</a>
      <a href="/learn/en" class="nav-link">🇬🇧 English</a>
      <a href="/learn/ja" class="nav-link">🇯🇵 Japanese</a>
      <a href="/learn/zh" class="nav-link">🇨🇳 Chinese</a>
    <% } %>
  </nav>
  <div class="topbar-right">
    <% if (user) { %>
      <span class="streak-badge">🔥 <%= user.streak || 0 %></span>
      <span class="xp-badge">⚡ <%= user.xp || 0 %> XP</span>
      <a href="/profile" class="nav-link user-link"><%= user.username %></a>
      <a href="/logout" class="btn-outline btn-sm">ออกจากระบบ</a>
    <% } else { %>
      <a href="/login" class="btn-outline btn-sm">เข้าสู่ระบบ</a>
      <a href="/register" class="btn-primary btn-sm">สมัครสมาชิก</a>
    <% } %>
  </div>
</header>
