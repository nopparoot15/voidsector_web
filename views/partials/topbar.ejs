<%
  const curPath = locals.currentPath || '';
  function isActive(href) {
    if (href === '/') return curPath === '/';
    return curPath.startsWith(href);
  }
%>
<header class="fb-topbar">

  <!-- LEFT: logo + search -->
  <div class="fb-topbar__left">
    <a href="/" class="fb-topbar-logo">
      <span class="fb-topbar-logo__dot"></span>
      <span class="fb-topbar-logo__text">VS</span>
    </a>
    <div class="fb-topbar-search" style="position:relative">
      <svg class="fb-search-icon" viewBox="0 0 20 20" fill="none"><circle cx="8.5" cy="8.5" r="5.5" stroke="currentColor" stroke-width="1.8"/><path d="M13 13l3.5 3.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
      <input type="text" placeholder="ค้นหา VoidSector" class="fb-search-input" id="globalSearch" autocomplete="off">
      <div class="search-dropdown hidden" id="search-dropdown"></div>
    </div>
  </div>

  <!-- CENTER: nav tabs -->
  <nav class="fb-topbar__center">
    <a href="/" class="fb-navtab<%= isActive('/') ? ' fb-navtab--active' : '' %>" title="หน้าหลัก">
      <svg viewBox="0 0 24 24" fill="none"><path d="M3 9.5L12 3l9 6.5V20a1 1 0 01-1 1H5a1 1 0 01-1-1V9.5z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><path d="M9 21V12h6v9" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
    </a>
    <a href="/arcade" class="fb-navtab<%= isActive('/arcade') ? ' fb-navtab--active' : '' %>" title="Arcade">
      <svg viewBox="0 0 24 24" fill="none"><rect x="2" y="6" width="20" height="12" rx="3" stroke="currentColor" stroke-width="1.8"/><path d="M8 12h4M10 10v4M16 11h.01M18 13h.01" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
    </a>
    <a href="/learning" class="fb-navtab<%= isActive('/learning') || isActive('/learn') ? ' fb-navtab--active' : '' %>" title="เรียน">
      <svg viewBox="0 0 24 24" fill="none"><path d="M12 3L2 8l10 5 10-5-10-5z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><path d="M2 17l10 5 10-5M2 12l10 5 10-5" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
    </a>
    <a href="/leaderboard" class="fb-navtab<%= isActive('/leaderboard') ? ' fb-navtab--active' : '' %>" title="Leaderboard">
      <svg viewBox="0 0 24 24" fill="none"><path d="M18 20V10M12 20V4M6 20v-6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
    </a>
    <a href="/tools" class="fb-navtab<%= isActive('/tools') ? ' fb-navtab--active' : '' %>" title="Tools">
      <svg viewBox="0 0 24 24" fill="none"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3-3a6 6 0 01-7 7l-7.2 7.2a2 2 0 01-2.8-2.8L11 11a6 6 0 017-7l-3.3 3.3z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
    </a>
  </nav>

  <!-- RIGHT: user / auth -->
  <div class="fb-topbar__right">
    <!-- Theme toggle -->
    <button class="theme-toggle-btn" onclick="VSTheme.toggle()" title="เปลี่ยนธีม" id="theme-toggle-btn">
      <svg id="theme-icon-dark" viewBox="0 0 24 24" fill="none" width="20" height="20"><path d="M21 12.79A9 9 0 1111.21 3a7 7 0 109.79 9.79z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
      <svg id="theme-icon-light" viewBox="0 0 24 24" fill="none" width="20" height="20" style="display:none"><circle cx="12" cy="12" r="5" stroke="currentColor" stroke-width="1.8"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
    </button>
    <% if (user) { %>
      <!-- Chat button -->
      <button class="fb-topbar-icon-btn" id="chat-btn" title="แชท">
        <svg viewBox="0 0 24 24" fill="none" width="22" height="22"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <span class="fb-topbar-badge hidden" id="chat-badge">0</span>
      </button>
      <!-- Notification bell -->
      <button class="fb-topbar-icon-btn" id="notif-btn" title="การแจ้งเตือน">
        <svg viewBox="0 0 24 24" fill="none" width="22" height="22"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 01-3.46 0" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <span class="fb-topbar-badge hidden" id="notif-badge">0</span>
      </button>
      <!-- Avatar -->
      <a href="/profile" class="fb-topbar-avatar" title="<%= user.username %>">
        <% if (user.avatar) { %>
          <img src="<%= user.avatar %>" alt="<%= user.username %>" onerror="this.src='/images/avatar-default.svg';this.onerror=null">
        <% } else { %>
          <span class="fb-topbar-avatar__init"><%= user.username.charAt(0).toUpperCase() %></span>
        <% } %>
      </a>
      <a href="/logout" class="fb-topbar-logout" title="ออกจากระบบ">
        <svg viewBox="0 0 24 24" fill="none"><path d="M17 16l4-4m0 0l-4-4m4 4H7M13 5H5a2 2 0 00-2 2v10a2 2 0 002 2h8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    <% } else { %>
      <a href="/login"    class="fb-topbar-btn fb-topbar-btn--ghost">เข้าสู่ระบบ</a>
      <a href="/register" class="fb-topbar-btn">สมัครฟรี</a>
    <% } %>
  </div>

</header>

<!-- Notification dropdown -->
<div class="fb-panel hidden" id="notif-panel">
  <div class="fb-panel-head">
    <span class="fb-panel-title">การแจ้งเตือน</span>
    <button class="fb-panel-read-all" id="notif-read-all">ทำเครื่องหมายว่าอ่านแล้ว</button>
  </div>
  <div class="fb-panel-body" id="notif-list">
    <div class="fb-panel-empty">ยังไม่มีการแจ้งเตือน</div>
  </div>
</div>

<!-- Chat dropdown -->
<div class="fb-panel hidden" id="chat-panel">
  <div class="fb-panel-head">
    <span class="fb-panel-title">แชท</span>
    <div class="fb-panel-head-icons">
      <button class="fb-panel-icon-btn" id="chat-new-btn" title="แชทใหม่">
        <svg viewBox="0 0 24 24" fill="none" width="18" height="18"><path d="M12 20h9M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
  </div>
  <div class="fb-panel-search">
    <svg style="position:absolute;left:24px;top:50%;transform:translateY(-50%);width:14px;height:14px;color:rgba(235,245,255,.4);pointer-events:none;z-index:1;" viewBox="0 0 20 20" fill="none"><circle cx="8.5" cy="8.5" r="5.5" stroke="currentColor" stroke-width="1.8"/><path d="M13 13l3.5 3.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
    <input type="text" placeholder="ค้นหา" class="fb-panel-search-inp" id="chat-search" style="padding-left:36px;">
  </div>
  <div class="fb-panel-tabs">
    <button class="fb-panel-tab fb-panel-tab--active" data-chat-tab="all">ทั้งหมด</button>
    <button class="fb-panel-tab" data-chat-tab="unread">ยังไม่ได้อ่าน</button>
  </div>
  <div class="fb-panel-body" id="chat-friend-list">
    <div class="fb-panel-empty">กำลังโหลด…</div>
  </div>
</div>
<div class="fb-search-dropdown hidden" id="fb-search-drop"></div>
<script>
// ── Notification & Chat System ───────────────────────────────────
(function(){
  if (!<%- JSON.stringify(!!locals.user) %>) return;

  // ── Sound ─────────────────────────────────────────────────────
  let audioCtx;
  function getAudioCtx(){
    if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    return audioCtx;
  }
  function playNotifSound(){
    try {
      const ctx = getAudioCtx();
      const osc = ctx.createOscillator(), gain = ctx.createGain();
      osc.connect(gain); gain.connect(ctx.destination);
      osc.frequency.setValueAtTime(880, ctx.currentTime);
      osc.frequency.exponentialRampToValueAtTime(440, ctx.currentTime + 0.15);
      gain.gain.setValueAtTime(0.25, ctx.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.3);
      osc.start(ctx.currentTime); osc.stop(ctx.currentTime + 0.3);
    } catch(e){}
  }
  function playDmSound(){
    try {
      const ctx = getAudioCtx();
      // double-ping: two short high notes
      [0, 0.12].forEach((delay, i) => {
        const osc = ctx.createOscillator(), gain = ctx.createGain();
        osc.connect(gain); gain.connect(ctx.destination);
        osc.type = 'sine';
        osc.frequency.setValueAtTime(i === 0 ? 1046 : 1318, ctx.currentTime + delay);
        gain.gain.setValueAtTime(0, ctx.currentTime + delay);
        gain.gain.linearRampToValueAtTime(0.22, ctx.currentTime + delay + 0.01);
        gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + delay + 0.18);
        osc.start(ctx.currentTime + delay);
        osc.stop(ctx.currentTime + delay + 0.2);
      });
    } catch(e){}
  }

  // ── DM Toast ───────────────────────────────────────────────────
  let dmUnread = 0;
  const chatBadgeEl = document.getElementById('chat-badge');

  function bumpChatBadge(){
    dmUnread++;
    chatBadgeEl.textContent = dmUnread > 99 ? '99+' : dmUnread;
    chatBadgeEl.classList.remove('hidden');
  }
  function clearChatBadge(){
    dmUnread = 0;
    chatBadgeEl.classList.add('hidden');
  }

  // expose so chat-dock can clear badge when user opens DM
  window.VS_CLEAR_CHAT_BADGE = clearChatBadge;
  window.VS_REFRESH_NOTIFY = function(){ /* called by chat-dock — no-op here, badge handled separately */ };

  let toastContainer = document.getElementById('vs-toast-container');
  if (!toastContainer) {
    toastContainer = document.createElement('div');
    toastContainer.id = 'vs-toast-container';
    toastContainer.style.cssText = 'position:fixed;top:70px;right:14px;z-index:9999;display:flex;flex-direction:column-reverse;gap:8px;pointer-events:none;';
    document.body.appendChild(toastContainer);
  }

  function showDmToast(from, roomId){
    const toast = document.createElement('div');
    toast.style.cssText = `
      pointer-events:auto;
      display:flex;align-items:center;gap:10px;
      background:rgba(14,20,40,.95);
      border:1px solid rgba(121,247,255,.25);
      border-radius:12px;
      padding:10px 14px;
      box-shadow:0 8px 32px rgba(0,0,0,.6);
      backdrop-filter:blur(12px);
      cursor:pointer;
      min-width:220px;max-width:300px;
      animation:vsToastIn .25s cubic-bezier(.2,.9,.2,1) both;
      font-family:inherit;
    `;
    const init = String(from||'?').trim().charAt(0).toUpperCase();
    toast.innerHTML = `
      <div style="width:36px;height:36px;border-radius:50%;background:rgba(121,247,255,.18);
        border:1.5px solid rgba(121,247,255,.35);display:flex;align-items:center;
        justify-content:center;font-weight:700;font-size:15px;color:#79f7ff;flex-shrink:0;">${esc(init)}</div>
      <div style="flex:1;min-width:0;">
        <div style="font-size:13px;font-weight:700;color:rgba(235,245,255,.95);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${esc(from)}</div>
        <div style="font-size:11.5px;color:rgba(235,245,255,.5);margin-top:2px;">ส่งข้อความถึงคุณ</div>
      </div>
      <div style="font-size:18px;flex-shrink:0;">💬</div>
    `;
    if (!document.getElementById('vs-toast-style')) {
      const s = document.createElement('style');
      s.id = 'vs-toast-style';
      s.textContent = `
        @keyframes vsToastIn { from{transform:translateX(20px);opacity:0} to{transform:translateX(0);opacity:1} }
        @keyframes vsToastOut { from{transform:translateX(0);opacity:1} to{transform:translateX(20px);opacity:0} }
      `;
      document.head.appendChild(s);
    }
    toast.addEventListener('click', () => {
      toast.remove();
      if (window.VS_CHAT_DOCK && roomId) {
        // open DM by friend — we use from name as fallback
        window.VS_CHAT_DOCK.openDmByRoom && window.VS_CHAT_DOCK.openDmByRoom(roomId, from);
      }
    });
    toastContainer.appendChild(toast);
    setTimeout(() => {
      toast.style.animation = 'vsToastOut .2s ease forwards';
      setTimeout(() => toast.remove(), 200);
    }, 4500);
  }

  // ── Notifications ─────────────────────────────────────────────
  const notifBtn   = document.getElementById('notif-btn');
  const notifPanel = document.getElementById('notif-panel');
  const notifBadge = document.getElementById('notif-badge');
  const notifList  = document.getElementById('notif-list');
  const readAllBtn = document.getElementById('notif-read-all');
  let prevUnread = 0;

  function notifMsg(n){
    const map = { like: 'ถูกใจโพสต์ของคุณ', comment: 'แสดงความคิดเห็นในโพสต์ของคุณ', friend_request: 'ส่งคำขอเพิ่มเป็นเพื่อน' };
    return `<strong>${esc(n.from_username||'ผู้ใช้')}</strong> ${map[n.type]||n.type}`;
  }

  window.acceptFriendReq = async function(fromUserId, btn){
    btn.disabled = true;
    const r = await fetch('/friends/request/accept-by-user', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ from_user_id: fromUserId })
    });
    const { ok } = await r.json();
    if (ok) {
      btn.closest('.fb-notif-item').querySelector('.fb-notif-actions').innerHTML = '<span style="font-size:12px;color:#34d399">เป็นเพื่อนกันแล้ว ✓</span>';
    } else {
      btn.disabled = false;
    }
  };
  window.declineFriendReq = async function(fromUserId, btn){
    btn.disabled = true;
    const r = await fetch('/friends/request/decline-by-user', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ from_user_id: fromUserId })
    });
    const { ok } = await r.json();
    if (ok) {
      btn.closest('.fb-notif-item').remove();
    } else {
      btn.disabled = false;
    }
  };

  async function loadNotifs(){
    try{
      const r = await fetch('/api/notifications');
      const {ok,notifications,unread} = await r.json();
      if(!ok) return;
      if(unread > prevUnread && prevUnread >= 0){ playNotifSound(); }
      prevUnread = unread;
      if(unread > 0){ notifBadge.textContent = unread > 99 ? '99+' : unread; notifBadge.classList.remove('hidden'); }
      else { notifBadge.classList.add('hidden'); }
      notifList.innerHTML = notifications.length ? notifications.map(n=>`
        <div class="fb-notif-item ${n.is_read?'':'unread'}">
          <div class="fb-notif-avatar">
            ${n.from_avatar ? `<img src="${n.from_avatar}" alt="">` : `<div class="fb-notif-avatar-init">${esc((n.from_username||'?').slice(0,1).toUpperCase())}</div>`}
          </div>
          <div class="fb-notif-text">
            <div>${notifMsg(n)}</div>
            <div class="fb-notif-time">${timeAgo(n.created_at)}</div>
            ${n.type==='friend_request' ? `<div class="fb-notif-actions">
              <button class="fb-notif-accept" onclick="acceptFriendReq(${Number(n.from_user_id)},this)">รับ</button>
              <button class="fb-notif-decline" onclick="declineFriendReq(${Number(n.from_user_id)},this)">ปฏิเสธ</button>
            </div>` : ''}
          </div>
          ${!n.is_read ? '<div class="fb-notif-dot"></div>' : ''}
        </div>`).join('') : '<div class="fb-panel-empty">ยังไม่มีการแจ้งเตือน</div>';
    }catch(e){}
  }

  loadNotifs();
  setInterval(loadNotifs, 30000);

  // Real-time notification via socket
  (function waitNotifSocket(){
    const s = window.VS_SOCKET;
    if (s && typeof s.on === 'function') {
      s.on('vs:notification', loadNotifs);
      s.on('dm:notify', ({ from, roomId } = {}) => {
        playDmSound();
        bumpChatBadge();
        showDmToast(from || 'เพื่อน', roomId || null);
      });
    } else {
      setTimeout(waitNotifSocket, 300);
    }
  })();

  notifBtn.addEventListener('click', (e)=>{
    e.stopPropagation();
    chatPanel.classList.add('hidden');
    notifPanel.classList.toggle('hidden');
    if(!notifPanel.classList.contains('hidden')){
      fetch('/api/notifications/read',{method:'POST'}).then(()=>{ prevUnread=0; notifBadge.classList.add('hidden'); }).catch(()=>{});
    }
  });

  if(readAllBtn) readAllBtn.addEventListener('click', ()=>{
    fetch('/api/notifications/read',{method:'POST'}).then(()=>{ prevUnread=0; notifBadge.classList.add('hidden'); loadNotifs(); }).catch(()=>{});
  });

  // ── Chat ──────────────────────────────────────────────────────
  const chatBtn    = document.getElementById('chat-btn');
  const chatPanel  = document.getElementById('chat-panel');
  const chatSearch = document.getElementById('chat-search');
  const chatList   = document.getElementById('chat-friend-list');
  let allThreads = [];   // dm_threads from summary
  let allFriends = [];   // friends without threads
  let chatTabActive = 'all';

  async function loadChatData(){
    try{
      // fetch both in parallel
      const [sr, fr] = await Promise.all([
        fetch('/api/notify/summary',{credentials:'include'}).then(r=>r.json()).catch(()=>({})),
        fetch('/friends/list',{credentials:'include'}).then(r=>r.json()).catch(()=>({})),
      ]);
      allThreads = sr.dm_threads || [];
      const threadFriendIds = new Set(allThreads.map(t=>Number(t.friend_id)));
      allFriends = (fr.friends||[]).filter(f=>!threadFriendIds.has(Number(f.id)));
      renderChat();
    }catch(e){}
  }

  function renderChat(query){
    const q = (query||'').toLowerCase();
    const globalItem = `
      <div class="fb-chat-item fb-chat-item--global" data-open-chat="global">
        <div class="fb-chat-avatar fb-chat-avatar--global">🌐</div>
        <div class="fb-chat-info">
          <div class="fb-chat-name">Global Chat</div>
          <div class="fb-chat-preview">แชทกับทุกคนใน VoidSector</div>
        </div>
      </div>`;

    let threads = allThreads;
    if(chatTabActive === 'unread') threads = threads.filter(t=>(t.unread_count||0)>0);
    if(q) threads = threads.filter(t=>t.username.toLowerCase().includes(q));

    let friends = allFriends;
    if(q) friends = friends.filter(f=>f.username.toLowerCase().includes(q));
    if(chatTabActive === 'unread') friends = [];

    const threadHtml = threads.map(t=>{
      const unread = Number(t.unread_count)||0;
      const lastMsg = t.last_message ? esc(t.last_message.slice(0,55)) : '<span style="opacity:.5">เริ่มการสนทนา</span>';
      return `<div class="fb-chat-item" data-open-chat="dm" data-friend-id="${t.friend_id}" data-friend-name="${esc(t.username)}" data-friend-avatar="${esc(t.avatar||'')}">
        <div class="fb-chat-avatar">
          ${t.avatar?`<img src="${esc(t.avatar)}" alt="" onerror="this.src='/images/avatar-default.svg';this.onerror=null">`:`<div class="fb-chat-avatar-init">${esc((t.username||'?').charAt(0).toUpperCase())}</div>`}
        </div>
        <div class="fb-chat-info">
          <div class="fb-chat-name${unread?' fb-chat-name--unread':''}">${esc(t.username)}</div>
          <div class="fb-chat-preview${unread?' fb-chat-preview--unread':''}">${lastMsg}</div>
        </div>
        <div class="fb-chat-meta">
          ${t.last_at?`<div class="fb-chat-time">${timeAgo(t.last_at)}</div>`:''}
          ${unread?`<div class="fb-chat-dot"></div>`:''}
        </div>
      </div>`;
    }).join('');

    const friendHtml = friends.map(f=>`
      <div class="fb-chat-item" data-open-chat="dm" data-friend-id="${f.id}" data-friend-name="${esc(f.username)}" data-friend-avatar="${esc(f.avatar||'')}">
        <div class="fb-chat-avatar">
          ${f.avatar?`<img src="${esc(f.avatar)}" alt="" onerror="this.src='/images/avatar-default.svg';this.onerror=null">`:`<div class="fb-chat-avatar-init">${esc((f.username||'?').charAt(0).toUpperCase())}</div>`}
        </div>
        <div class="fb-chat-info">
          <div class="fb-chat-name">${esc(f.username)}</div>
          <div class="fb-chat-preview" style="opacity:.45">เริ่มการสนทนา</div>
        </div>
      </div>`).join('');

    const empty = !threads.length && !friends.length
      ? '<div class="fb-panel-empty">'+(chatTabActive==='unread'?'ไม่มีข้อความที่ยังไม่อ่าน':'ยังไม่มีเพื่อน')+'</div>'
      : '';

    chatList.innerHTML = globalItem + threadHtml + friendHtml + empty;
  }

  chatBtn.addEventListener('click', (e)=>{
    e.stopPropagation();
    notifPanel.classList.add('hidden');
    chatPanel.classList.toggle('hidden');
    if(!chatPanel.classList.contains('hidden')){
      loadChatData();
      clearChatBadge();
    }
  });

  // Tabs
  chatPanel.querySelectorAll('[data-chat-tab]').forEach(tab=>{
    tab.addEventListener('click', ()=>{
      chatPanel.querySelectorAll('[data-chat-tab]').forEach(t=>t.classList.remove('fb-panel-tab--active'));
      tab.classList.add('fb-panel-tab--active');
      chatTabActive = tab.dataset.chatTab;
      renderChat(chatSearch.value);
    });
  });

  // Close chat panel when a chat item is clicked
  chatPanel.addEventListener('click', e => {
    if (e.target.closest('[data-open-chat]')) chatPanel.classList.add('hidden');
  });

  if(chatSearch) chatSearch.addEventListener('input', ()=>{
    renderChat(chatSearch.value.trim());
  });

  // Close panels on outside click
  document.addEventListener('click', (e)=>{
    if(!notifBtn.contains(e.target) && !notifPanel.contains(e.target)) notifPanel.classList.add('hidden');
    if(!chatBtn.contains(e.target) && !chatPanel.contains(e.target)) chatPanel.classList.add('hidden');
  });
})();

// ── Theme icon sync ──────────────────────────────────────────────
(function(){
  function syncIcon(){
    const dark = document.documentElement.getAttribute('data-theme') !== 'light';
    const d = document.getElementById('theme-icon-dark');
    const l = document.getElementById('theme-icon-light');
    if(d) d.style.display = dark ? '' : 'none';
    if(l) l.style.display = dark ? 'none' : '';
  }
  syncIcon();
  const origToggle = VSTheme.toggle.bind(VSTheme);
  VSTheme.toggle = function(){ origToggle(); syncIcon(); };
})();

// ── Search ───────────────────────────────────────────────────────
(function(){
  const inp  = document.getElementById('globalSearch');
  const drop = document.getElementById('search-dropdown');
  if (!inp || !drop) return;
  let timer;
  function avHtml(a, u){
    if(a) return `<img src="${a}" class="search-result-avatar" style="width:32px;height:32px;border-radius:50%;object-fit:cover" alt="" onerror="this.style.display='none'">`;
    return `<div class="search-result-avatar">${esc((u||'?').slice(0,1).toUpperCase())}</div>`;
  }
  inp.addEventListener('input', ()=>{
    clearTimeout(timer);
    const q = inp.value.trim();
    if(!q){ drop.classList.add('hidden'); drop.innerHTML=''; return; }
    timer = setTimeout(async ()=>{
      try{
        const r = await fetch(`/api/search?q=${encodeURIComponent(q)}`);
        const { ok, users=[], posts=[] } = await r.json();
        if(!ok||(users.length+posts.length===0)){
          drop.innerHTML='<div class="search-no-results">ไม่พบผลลัพธ์</div>';
          drop.classList.remove('hidden'); return;
        }
        let html = '';
        if(users.length){
          html += '<div class="search-section-label">ผู้ใช้</div>';
          html += users.map(u=>`
            <a class="search-result-item" href="/user/${encodeURIComponent(u.username)}">
              ${avHtml(u.avatar, u.username)}
              <div><div class="search-result-name">${esc(u.username)}</div></div>
            </a>`).join('');
        }
        if(posts.length){
          html += '<div class="search-section-label">โพสต์</div>';
          html += posts.map(p=>`
            <a class="search-result-item" href="/user/${encodeURIComponent(p.username)}">
              ${avHtml(p.avatar, p.username)}
              <div>
                <div class="search-result-name">${esc(p.username)}</div>
                <div class="search-result-sub">${esc((p.text||'').slice(0,60))}</div>
              </div>
            </a>`).join('');
        }
        drop.innerHTML = html;
        drop.classList.remove('hidden');
      }catch(e){}
    }, 280);
  });
  inp.addEventListener('keydown', e=>{
    if(e.key==='Escape'){ drop.classList.add('hidden'); inp.blur(); }
  });
  document.addEventListener('click', e=>{
    if(!inp.closest('.fb-topbar-search').contains(e.target)) drop.classList.add('hidden');
  });
})();
</script>

