<!-- views/partials/chat-widget.ejs -->

<script>
  // ใช้ให้ JS รู้ว่าเราเป็นใคร (ไว้จัด bubble ซ้าย/ขวา)
  window.__USER__ = <%- JSON.stringify(user || null) %>;
</script>

<link rel="stylesheet" href="/css/chat-widget.css">

<div id="chat-widget" class="chat-collapsed">
  <div id="chat-header" role="button" aria-label="Toggle chat">
    <span>💬 GLOBAL CHAT</span>
    <button id="chat-toggle" type="button" aria-label="Toggle chat">▲</button>
  </div>

  <div id="chat-body">
    <div class="chat-messages" id="chat-messages"></div>

    <form id="chat-form" autocomplete="off">
      <input
        type="text"
        id="chat-input"
        placeholder="พิมพ์ข้อความแล้วกด Enter..."
        autocomplete="off"
      />
    </form>
  </div>
</div>

<script src="/socket.io/socket.io.js"></script>
<script src="/js/chat-widget.js"></script>
